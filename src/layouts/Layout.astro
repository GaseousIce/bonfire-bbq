---
import '../styles/global.css';
import LoadingScreen from '../components/LoadingScreen.astro';
import Navbar from '../components/Navbar.astro';
import { heroTandoor } from '../assets/images';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Bonfire Barbecue | Indian Coal & Clay Oven | Tandoor & Grill Craft',
  description = 'Experience the primal art of clay tandoors, open-fire sigree kebabs, and slow-steamed biryani. A premium, cinematic Indian culinary story.',
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />

    <!-- Preconnect hints for Google Fonts — saves 200-500ms font TTFB -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Space+Grotesk:wght@400;500;700&family=Space+Mono:wght@400;700&family=Newsreader:ital,opsz,wght@1,6..72,400&display=swap"
    />

    <!-- Preconnect for Unsplash images (Hero + About sections) -->
    <link rel="preconnect" href="https://images.unsplash.com" />

    <!-- Preload hero image -->
    <link rel="preload" href={heroTandoor.src} as="image" type="image/webp" fetchpriority="high" />

    <!-- Primary Meta Tags -->
    <title>{title}</title>
    <meta name="title" content={title} />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />

    <style>
      /* Hide scrollbar for clean presentation but allow scrolling */
      html {
        scrollbar-width: thin;
        scrollbar-color: #313131 #131313;
      }

      /* Promote smooth-wrapper/content to compositor layers */
      #smooth-wrapper,
      #smooth-content {
        will-change: transform;
      }

      /* Webkit scrollbar customization */
      ::-webkit-scrollbar {
        width: 6px;
      }
      ::-webkit-scrollbar-track {
        background: #131313;
      }
      ::-webkit-scrollbar-thumb {
        background: #313131;
        border-radius: 3px;
      }
      ::-webkit-scrollbar-thumb:hover {
        background: #3cffd0;
      }
    </style>
  </head>
  <body
    class="bg-canvas-black text-hazard-white selection:bg-brand-mint selection:text-canvas-black font-sans antialiased overflow-x-hidden"
  >
    <LoadingScreen />
    <Navbar />
    <div id="smooth-wrapper">
      <div id="smooth-content">
        <slot />
      </div>
    </div>
    <script>
      import { gsap } from 'gsap';
      import { ScrollTrigger } from 'gsap/ScrollTrigger';
      import { ScrollSmoother } from 'gsap/ScrollSmoother';

      // Extend Window so TypeScript recognises window.__smoother
      declare global {
        interface Window {
          __smoother?: ScrollSmoother;
        }
      }

      gsap.registerPlugin(ScrollTrigger, ScrollSmoother);

      ScrollTrigger.normalizeScroll(true);

      // Only run ScrollSmoother on desktop — reduces jank on low-end mobile devices
      const mediaMatcher = gsap.matchMedia();
      mediaMatcher.add('(min-width: 768px)', () => {
        window.__smoother = ScrollSmoother.create({
          wrapper: '#smooth-wrapper',
          content: '#smooth-content',
          smooth: 0.6,
        });
        requestAnimationFrame(() => ScrollTrigger.refresh());
      });
    </script>
  </body>
</html>
