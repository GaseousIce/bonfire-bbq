---
import '../styles/global.css';
import LoadingScreen from '../components/LoadingScreen.astro';
import Navbar from '../components/Navbar.astro';
import PageTransition from '../components/PageTransition.astro';
import { getImage } from 'astro:assets';
import { heroTandoor } from '../assets/images';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Bonfire Barbecue | Indian Coal & Clay Oven | Tandoor & Grill Craft',
  description = 'Experience the primal art of clay tandoors, open-fire sigree kebabs, and slow-steamed biryani. A premium, cinematic Indian culinary story.',
} = Astro.props;

const heroImage = await getImage({
  src: heroTandoor,
  format: 'webp',
  width: 1920,
  quality: 82,
});
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />

    <!-- Preconnect hints for Google Fonts — saves 200-500ms font TTFB -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Space+Grotesk:wght@400;500;700&family=Space+Mono:wght@400;700&family=Newsreader:ital,opsz,wght@1,6..72,400&display=swap"
    />

    <!-- Preconnect for Unsplash images (Hero + About sections) -->
    <link rel="preconnect" href="https://images.unsplash.com" />

    <!-- Preload hero image (WebP via getImage — avoids preloading the 776 KB source PNG) -->
    <link rel="preload" href={heroImage.src} as="image" type="image/webp" fetchpriority="high" />

    <!-- Primary Meta Tags -->
    <title>{title}</title>
    <meta name="title" content={title} />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />

    <style>
      /* Hide scrollbar for clean presentation but allow scrolling */
      html {
        scrollbar-width: thin;
        scrollbar-color: #313131 #131313;
      }

      /* Promote smooth-wrapper/content to compositor layers */
      #smooth-wrapper,
      #smooth-content {
        will-change: transform;
      }

      /* Webkit scrollbar customization */
      ::-webkit-scrollbar {
        width: 6px;
      }
      ::-webkit-scrollbar-track {
        background: #131313;
      }
      ::-webkit-scrollbar-thumb {
        background: #313131;
        border-radius: 3px;
      }
      ::-webkit-scrollbar-thumb:hover {
        background: #3cffd0;
      }
    </style>
  </head>
  <body
    class="bg-canvas-black text-hazard-white selection:bg-brand-mint selection:text-canvas-black font-sans antialiased overflow-x-hidden"
  >
    <LoadingScreen />
    <Navbar />
    <div id="smooth-wrapper">
      <div id="smooth-content">
        <slot />
      </div>
    </div>
    <PageTransition />
    <script>
      import { gsap } from 'gsap';
      import { ScrollTrigger } from 'gsap/ScrollTrigger';
      import { ScrollSmoother } from 'gsap/ScrollSmoother';
      import { MorphSVGPlugin } from 'gsap/MorphSVGPlugin';

      // Extend Window so TypeScript recognises global helpers
      declare global {
        interface Window {
          __smoother?: ScrollSmoother;
          __pageTransition?: (href: string) => void;
        }
      }

      gsap.registerPlugin(ScrollTrigger, ScrollSmoother, MorphSVGPlugin);

      ScrollTrigger.normalizeScroll(true);

      window.__smoother = ScrollSmoother.create({
        wrapper: '#smooth-wrapper',
        content: '#smooth-content',
        smooth: 0.6,
      });
      requestAnimationFrame(() => ScrollTrigger.refresh());

      // ── Page transition orchestration ──────────────────────────────
      let _transitionActive = false;

      window.__pageTransition = (href: string): void => {
        if (_transitionActive) return;
        _transitionActive = true;

        const wipePathUV = document.getElementById('wipe-path-uv') as SVGPathElement | null;
        const wipePathMint = document.getElementById('wipe-path-mint') as SVGPathElement | null;
        const smoother = window.__smoother;
        if (!wipePathUV || !wipePathMint) {
          _transitionActive = false;
          return;
        }

        const HIDDEN = 'M 100,0 L 100,0 Q 100,50 100,100 L 100,100 Z';
        const COVER = 'M 100,0 L 0,0 Q -8,50 0,100 L 100,100 Z';

        // Phase 1 — UV leads, mint follows
        gsap.to(wipePathUV, {
          morphSVG: { shape: COVER },
          duration: 0.75,
          ease: 'power2.inOut',
        });
        gsap.to(wipePathMint, {
          morphSVG: { shape: COVER },
          duration: 0.75,
          ease: 'power2.inOut',
          delay: 0.08,
          onComplete: () => {
            // Instant-jump to the target section while fully covered
            if (href === '#hero') {
              if (smoother) smoother.scrollTo(0, false);
              else window.scrollTo({ top: 0 });
            } else {
              const target = document.querySelector(href);
              if (target) {
                if (smoother) {
                  const rect = target.getBoundingClientRect();
                  smoother.scrollTo(smoother.scrollTop() + rect.top - 80, false);
                } else {
                  target.scrollIntoView();
                }
              }
            }

            ScrollTrigger.refresh();

            // Phase 2 — settle, then mint retracts first, UV follows
            gsap.delayedCall(0.15, () => {
              gsap.to(wipePathMint, {
                morphSVG: { shape: HIDDEN },
                duration: 0.75,
                ease: 'power2.inOut',
              });
              gsap.to(wipePathUV, {
                morphSVG: { shape: HIDDEN },
                duration: 0.75,
                ease: 'power2.inOut',
                delay: 0.08,
                onComplete: () => {
                  _transitionActive = false;
                },
              });
            });
          },
        });
      };
    </script>
  </body>
</html>
