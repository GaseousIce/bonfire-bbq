---
import '../styles/global.css';
import LoadingScreen from '../components/LoadingScreen.astro';
import Navbar from '../components/Navbar.astro';
import PageTransition from '../components/PageTransition.astro';
import { getImage } from 'astro:assets';
import { heroTandoor } from '../assets/images';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Bonfire Barbecue | Indian Coal & Clay Oven | Tandoor & Grill Craft',
  description = 'Experience the primal art of clay tandoors, open-fire sigree kebabs, and slow-steamed biryani. A premium, cinematic Indian culinary story.',
} = Astro.props;

const heroImage = await getImage({
  src: heroTandoor,
  format: 'webp',
  width: 1920,
  quality: 82,
});
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />

    <!-- Preconnect hints for Google Fonts — saves 200-500ms font TTFB -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Space+Grotesk:wght@400;500;700&family=Space+Mono:wght@400;700&family=Newsreader:ital,opsz,wght@1,6..72,400&display=swap"
      crossorigin="anonymous"
    />

    <!-- Preconnect for Unsplash images (Hero + About sections) -->
    <link rel="preconnect" href="https://images.unsplash.com" />

    <!-- Preload hero image (WebP via getImage — avoids preloading the 776 KB source PNG) -->
    <link rel="preload" href={heroImage.src} as="image" type="image/webp" fetchpriority="high" />

    <!-- Primary Meta Tags -->
    <title>{title}</title>
    <meta name="title" content={title} />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />

    <!-- Content Security Policy -->
    <meta
      http-equiv="Content-Security-Policy"
      content="default-src 'self'; style-src 'self' https://fonts.googleapis.com 'unsafe-inline'; font-src 'self' https://fonts.gstatic.com; img-src 'self' https://images.unsplash.com; script-src 'self' 'unsafe-inline'; connect-src 'self'; media-src 'none'; object-src 'none'; frame-src 'none'; base-uri 'self'; form-action 'self'"
    />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />

    <style>
      /* Hide scrollbar for clean presentation but allow scrolling */
      html {
        scrollbar-width: thin;
        scrollbar-color: #313131 #131313;
      }

      /* Promote smooth-wrapper/content to compositor layers on desktop where ScrollSmoother is active */
      @media (min-width: 768px) {
        #smooth-wrapper,
        #smooth-content {
          will-change: transform;
        }
      }

      /* Webkit scrollbar customization */
      ::-webkit-scrollbar {
        width: 6px;
      }
      ::-webkit-scrollbar-track {
        background: #131313;
      }
      ::-webkit-scrollbar-thumb {
        background: #313131;
        border-radius: 3px;
      }
      ::-webkit-scrollbar-thumb:hover {
        background: #3cffd0;
      }
    </style>
  </head>
  <body
    class="bg-canvas-black text-hazard-white selection:bg-brand-mint selection:text-canvas-black font-sans antialiased overflow-x-hidden"
  >
    <LoadingScreen />
    <Navbar />
    <div id="smooth-wrapper">
      <div id="smooth-content">
        <slot />
      </div>
    </div>
    <PageTransition />
    <script>
      import { gsap } from 'gsap';
      import { ScrollTrigger } from 'gsap/ScrollTrigger';
      import { ScrollSmoother } from 'gsap/ScrollSmoother';
      import { SplitText } from 'gsap/SplitText';

      declare global {
        interface Window {
          __smoother?: ScrollSmoother;
          __pageTransition?: (href: string, originX?: number, originY?: number) => void;
        }
      }

      gsap.registerPlugin(ScrollTrigger, ScrollSmoother, SplitText);

      const smootherMM = gsap.matchMedia();
      smootherMM.add('(min-width: 768px)', () => {
        ScrollTrigger.normalizeScroll(true);
        window.__smoother = ScrollSmoother.create({
          wrapper: '#smooth-wrapper',
          content: '#smooth-content',
          smooth: 0.6,
        });
        return () => {
          window.__smoother?.kill();
          window.__smoother = undefined;
          ScrollTrigger.normalizeScroll(false);
        };
      });
      requestAnimationFrame(() => ScrollTrigger.refresh());

      const breakpointWatcher = window.matchMedia('(min-width: 768px)');
      breakpointWatcher.addEventListener('change', () => {
        requestAnimationFrame(() => ScrollTrigger.refresh());
      });

      // ── Page transition SplitText initialization (once, not on every click) ──
      let pageTransitionBrandCharsTween: gsap.core.Tween | null = null;
      {
        const brandSplitTextElement = document.querySelector('.split');
        if (brandSplitTextElement) {
          try {
            SplitText.create('.split', {
              type: 'chars',
              autoSplit: true,
              mask: 'chars',
              onSplit: (self: any) => {
                // Symmetrical center-outward reveal with silky power3.out easing
                pageTransitionBrandCharsTween = gsap.from(self.chars, {
                  duration: 0.42,
                  yPercent: 45,
                  opacity: 0,
                  scale: 0.94,
                  stagger: {
                    amount: 0.16,
                    from: 'center',
                  },
                  ease: 'power3.out',
                  paused: true,
                });
              },
            });
          } catch (e) {
            console.warn('[PageTransition] SplitText init error:', e);
          }
        }
      }

      let isPageTransitionActive = false;

      const transferFocusToTargetSection = (targetHref: string) => {
        if (!targetHref || !targetHref.startsWith('#')) return;
        const targetSection =
          targetHref === '#hero'
            ? (document.querySelector('#hero') as HTMLElement | null) || document.body
            : (document.querySelector(targetHref) as HTMLElement | null);
        if (!targetSection) return;
        const focusableHeading =
          (targetSection.querySelector('h1, h2, h3, [role="heading"]') as HTMLElement | null) ||
          targetSection;
        focusableHeading.setAttribute('tabindex', '-1');
        focusableHeading.focus({ preventScroll: true });
      };

      window.__pageTransition = (
        targetHref: string,
        clickOriginX?: number,
        clickOriginY?: number,
      ): void => {
        if (isPageTransitionActive) return;
        isPageTransitionActive = true;

        const transitionOverlay = document.getElementById('page-transition') as HTMLElement | null;
        const haloWipeLayer = document.getElementById('pt-halo') as HTMLElement | null;
        const mintAccentWipeLayer = document.getElementById('pt-accent') as HTMLElement | null;
        const darkCanvasWipeLayer = document.getElementById('pt-wipe') as HTMLElement | null;
        const transitionContentWrapper = document.getElementById(
          'pt-content',
        ) as HTMLElement | null;
        const transitionBrandHeading = document.getElementById('pt-brand') as HTMLElement | null;
        const transitionKickerLabel = document.getElementById('pt-kicker') as HTMLElement | null;
        const scrollSmootherInstance = window.__smoother;

        const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

        // ── Reduced Motion Fallback: Smooth 150ms crossfade ──
        if (prefersReducedMotion) {
          if (!transitionOverlay) {
            isPageTransitionActive = false;
            return;
          }
          gsap.to(transitionOverlay, {
            autoAlpha: 1,
            duration: 0.1,
            onComplete: () => {
              try {
                if (targetHref === '#hero') {
                  if (scrollSmootherInstance) scrollSmootherInstance.scrollTo(0, false);
                  else window.scrollTo({ top: 0, behavior: 'auto' });
                } else if (targetHref?.startsWith('#')) {
                  const targetSection = document.querySelector(targetHref) as HTMLElement | null;
                  if (targetSection) {
                    if (scrollSmootherInstance)
                      scrollSmootherInstance.scrollTo(targetSection, false);
                    else targetSection.scrollIntoView({ behavior: 'auto' });
                  }
                }
                transferFocusToTargetSection(targetHref);
                ScrollTrigger.refresh();
              } catch (e) {
                console.warn('[PageTransition] Reduced motion scroll error:', e);
              }
              gsap.to(transitionOverlay, {
                autoAlpha: 0,
                duration: 0.1,
                onComplete: () => {
                  isPageTransitionActive = false;
                },
              });
            },
          });
          return;
        }

        if (
          !transitionOverlay ||
          !darkCanvasWipeLayer ||
          !transitionBrandHeading ||
          !mintAccentWipeLayer ||
          !haloWipeLayer
        ) {
          isPageTransitionActive = false;
          return;
        }

        const originX = clickOriginX !== undefined ? clickOriginX : window.innerWidth / 2;
        const originY = clickOriginY !== undefined ? clickOriginY : window.innerHeight / 2;
        const viewportCoverageMaxRadius = Math.sqrt(
          window.innerWidth * window.innerWidth + window.innerHeight * window.innerHeight,
        );
        const clipPathOriginPosition = `${originX}px ${originY}px`;

        // ── Reset & Setup Initial States ──
        gsap.set([haloWipeLayer, mintAccentWipeLayer, darkCanvasWipeLayer], {
          willChange: 'clip-path',
        });
        gsap.set(haloWipeLayer, { clipPath: `circle(0px at ${clipPathOriginPosition})` });
        gsap.set(mintAccentWipeLayer, { clipPath: `circle(0px at ${clipPathOriginPosition})` });
        gsap.set(darkCanvasWipeLayer, { clipPath: `circle(0px at ${clipPathOriginPosition})` });
        if (transitionContentWrapper)
          gsap.set(transitionContentWrapper, { scale: 0.88, opacity: 1 });
        gsap.set(transitionBrandHeading, { autoAlpha: 0, letterSpacing: '0.01em' });
        if (transitionKickerLabel)
          gsap.set(transitionKickerLabel, { autoAlpha: 0, y: 12, letterSpacing: '0.15em' });

        const resetGPUCompositorLayers = () => {
          gsap.set([haloWipeLayer, mintAccentWipeLayer, darkCanvasWipeLayer], {
            willChange: 'auto',
          });
          isPageTransitionActive = false;
        };

        const pageTransitionTimeline = gsap.timeline({
          onComplete: () => {
            pageTransitionTimeline.kill();
            resetGPUCompositorLayers();
          },
          onInterrupt: () => {
            resetGPUCompositorLayers();
          },
        });

        // ── Phase 1: Smooth Multi-Layer Radial Wave Expansion (0.0s → 0.58s) ──
        pageTransitionTimeline.set(transitionOverlay, { autoAlpha: 1, pointerEvents: 'auto' }, 0);

        // Layer 1: Ultraviolet Accent Halo expands first with smooth power3.inOut
        pageTransitionTimeline.to(
          haloWipeLayer,
          {
            clipPath: `circle(${viewportCoverageMaxRadius}px at ${clipPathOriginPosition})`,
            duration: 0.52,
            ease: 'power3.inOut',
          },
          0,
        );

        // Layer 2: Jelly Mint Leading Wave expands 30ms behind
        pageTransitionTimeline.to(
          mintAccentWipeLayer,
          {
            clipPath: `circle(${viewportCoverageMaxRadius}px at ${clipPathOriginPosition})`,
            duration: 0.52,
            ease: 'power3.inOut',
          },
          0.03,
        );

        // Layer 3: Canvas Dark Wipe follows 60ms behind for a rich mint edge
        pageTransitionTimeline.to(
          darkCanvasWipeLayer,
          {
            clipPath: `circle(${viewportCoverageMaxRadius}px at ${clipPathOriginPosition})`,
            duration: 0.52,
            ease: 'power3.inOut',
          },
          0.06,
        );

        // ── Phase 2: Fluid 3D Scale-Up & Typography Reveal (0.18s → 0.60s) ──
        if (transitionContentWrapper) {
          pageTransitionTimeline.to(
            transitionContentWrapper,
            {
              scale: 1,
              duration: 0.48,
              ease: 'power2.out',
            },
            0.18,
          );
        }

        pageTransitionTimeline.call(
          () => {
            if (transitionKickerLabel) {
              gsap.to(transitionKickerLabel, {
                autoAlpha: 1,
                y: 0,
                letterSpacing: '0.3em',
                duration: 0.38,
                ease: 'power2.out',
              });
            }
            gsap.set(transitionBrandHeading, { autoAlpha: 1 });
            gsap.to(transitionBrandHeading, {
              letterSpacing: '0.04em',
              duration: 0.42,
              ease: 'power2.out',
            });
            if (pageTransitionBrandCharsTween) {
              pageTransitionBrandCharsTween.restart();
            }
          },
          undefined,
          0.2,
        );

        // ── Phase 3: Execute Scroll Jump under full coverage (0.52s mark) ──
        pageTransitionTimeline.call(
          () => {
            try {
              if (targetHref === '#hero') {
                if (scrollSmootherInstance) scrollSmootherInstance.scrollTo(0, false);
                else window.scrollTo({ top: 0 });
              } else if (targetHref?.startsWith('#')) {
                const targetSection = document.querySelector(targetHref);
                if (targetSection) {
                  if (scrollSmootherInstance) scrollSmootherInstance.scrollTo(targetSection, false);
                  else targetSection.scrollIntoView();
                }
              }
              transferFocusToTargetSection(targetHref);
              requestAnimationFrame(() => ScrollTrigger.refresh());
            } catch (e) {
              console.warn('[PageTransition] scroll error:', e);
            }
          },
          undefined,
          0.52,
        );

        // ── Phase 4: Overlapping Smooth Unveil & Wave Collapse (0.85s → 1.30s) ──
        if (transitionContentWrapper) {
          pageTransitionTimeline.to(
            transitionContentWrapper,
            {
              scale: 1.03,
              opacity: 0,
              duration: 0.3,
              ease: 'power2.inOut',
            },
            0.82,
          );
        }

        pageTransitionTimeline.to(
          darkCanvasWipeLayer,
          {
            clipPath: `circle(0px at ${clipPathOriginPosition})`,
            duration: 0.45,
            ease: 'power3.inOut',
          },
          0.85,
        );

        pageTransitionTimeline.to(
          mintAccentWipeLayer,
          {
            clipPath: `circle(0px at ${clipPathOriginPosition})`,
            duration: 0.45,
            ease: 'power3.inOut',
          },
          0.87,
        );

        pageTransitionTimeline.to(
          haloWipeLayer,
          {
            clipPath: `circle(0px at ${clipPathOriginPosition})`,
            duration: 0.45,
            ease: 'power3.inOut',
          },
          0.89,
        );

        pageTransitionTimeline.set(
          transitionOverlay,
          { autoAlpha: 0, pointerEvents: 'none' },
          1.34,
        );
      };
    </script>
  </body>
</html>
