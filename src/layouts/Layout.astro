---
import '../styles/global.css';
import LoadingScreen from '../components/LoadingScreen.astro';
import Navbar from '../components/Navbar.astro';
import PageTransition from '../components/PageTransition.astro';
import { getImage } from 'astro:assets';
import { heroTandoor } from '../assets/images';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Bonfire Barbecue | Indian Coal & Clay Oven | Tandoor & Grill Craft',
  description = 'Experience the primal art of clay tandoors, open-fire sigree kebabs, and slow-steamed biryani. A premium, cinematic Indian culinary story.',
} = Astro.props;

const heroImage = await getImage({
  src: heroTandoor,
  format: 'webp',
  width: 1920,
  quality: 82,
});
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />

    <!-- Preconnect hints for Google Fonts — saves 200-500ms font TTFB -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Space+Grotesk:wght@400;500;700&family=Space+Mono:wght@400;700&family=Newsreader:ital,opsz,wght@1,6..72,400&display=swap"
    />

    <!-- Preconnect for Unsplash images (Hero + About sections) -->
    <link rel="preconnect" href="https://images.unsplash.com" />

    <!-- Preload hero image (WebP via getImage — avoids preloading the 776 KB source PNG) -->
    <link rel="preload" href={heroImage.src} as="image" type="image/webp" fetchpriority="high" />

    <!-- Primary Meta Tags -->
    <title>{title}</title>
    <meta name="title" content={title} />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />

    <style>
      /* Hide scrollbar for clean presentation but allow scrolling */
      html {
        scrollbar-width: thin;
        scrollbar-color: #313131 #131313;
      }

      /* Promote smooth-wrapper/content to compositor layers on desktop where ScrollSmoother is active */
      @media (min-width: 768px) {
        #smooth-wrapper,
        #smooth-content {
          will-change: transform;
        }
      }

      /* Webkit scrollbar customization */
      ::-webkit-scrollbar {
        width: 6px;
      }
      ::-webkit-scrollbar-track {
        background: #131313;
      }
      ::-webkit-scrollbar-thumb {
        background: #313131;
        border-radius: 3px;
      }
      ::-webkit-scrollbar-thumb:hover {
        background: #3cffd0;
      }
    </style>
  </head>
  <body
    class="bg-canvas-black text-hazard-white selection:bg-brand-mint selection:text-canvas-black font-sans antialiased overflow-x-hidden"
  >
    <LoadingScreen />
    <Navbar />
    <div id="smooth-wrapper">
      <div id="smooth-content">
        <slot />
      </div>
    </div>
    <PageTransition />
    <script>
      import { gsap } from 'gsap';
      import { ScrollTrigger } from 'gsap/ScrollTrigger';
      import { ScrollSmoother } from 'gsap/ScrollSmoother';
      import { SplitText } from 'gsap/SplitText';

      declare global {
        interface Window {
          __smoother?: ScrollSmoother;
          __pageTransition?: (href: string, originX?: number, originY?: number) => void;
        }
      }

      gsap.registerPlugin(ScrollTrigger, ScrollSmoother, SplitText);

      const isMobile = window.innerWidth < 768;

      if (!isMobile) {
        ScrollTrigger.normalizeScroll(true);
        window.__smoother = ScrollSmoother.create({
          wrapper: '#smooth-wrapper',
          content: '#smooth-content',
          smooth: 0.6,
        });
      }
      requestAnimationFrame(() => ScrollTrigger.refresh());

      // ── Page transition SplitText initialization (once, not on every click) ──
      let __ptCharsTween: gsap.core.Tween | null = null;
      {
        const splitEl = document.querySelector('.split');
        if (splitEl) {
          try {
            SplitText.create('.split', {
              type: 'chars',
              autoSplit: true,
              mask: 'chars',
              onSplit: (self: any) => {
                __ptCharsTween = gsap.from(self.chars, {
                  duration: 0.28,
                  yPercent: 40,
                  opacity: 0,
                  stagger: 0.04,
                  ease: 'elastic.out(1,0.5)',
                });
              },
            });
            // Pause the tween at start — we replay it on each nav click
            if (__ptCharsTween) __ptCharsTween.pause(0);
          } catch (e) {
            console.warn('[PageTransition] SplitText init error:', e);
          }
        }
      }

      let _transitionActive = false;

      window.__pageTransition = (href: string, originX?: number, originY?: number): void => {
        if (_transitionActive) return;
        _transitionActive = true;

        const ptOverlay = document.getElementById('page-transition') as HTMLElement | null;
        const ptWipe = document.getElementById('pt-wipe') as HTMLElement | null;
        const ptBrand = document.getElementById('pt-brand') as HTMLElement | null;
        const smoother = window.__smoother;
        if (!ptOverlay || !ptWipe || !ptBrand) {
          _transitionActive = false;
          return;
        }

        const cx = originX !== undefined ? originX : window.innerWidth / 2;
        const cy = originY !== undefined ? originY : window.innerHeight / 2;

        // Max radius to cover full viewport from any click point (viewport diagonal)
        const maxRadius = Math.sqrt(
          window.innerWidth * window.innerWidth + window.innerHeight * window.innerHeight,
        );

        const pos = `${cx}px ${cy}px`;

        gsap.set(ptWipe, { clipPath: `circle(0px at ${pos})` });

        const tl = gsap.timeline({
          onComplete: () => {
            tl.kill();
            _transitionActive = false;
          },
          onInterrupt: () => {
            _transitionActive = false;
          },
        });

        // Phase 1: Circle expand (0s start, 0.5s duration — slower to match text reveal)
        tl.set(ptOverlay, { autoAlpha: 1, pointerEvents: 'auto' });
        tl.to(
          ptWipe,
          {
            clipPath: `circle(${maxRadius}px at ${pos})`,
            duration: 0.5,
            ease: 'power2.inOut',
          },
          0,
        );

        // Phase 2: Text reveal via pre-initialized SplitText (offset +250ms after swipe)
        tl.call(
          () => {
            gsap.set(ptBrand, { autoAlpha: 1 });
            if (__ptCharsTween) {
              __ptCharsTween.restart();
            }
          },
          null,
          null,
          0.25,
        );

        // Phase 3: Navigate + cleanup (scroll while overlay is fully dark)
        tl.call(
          () => {
            try {
              if (href === '#hero') {
                if (smoother) smoother.scrollTo(0, false);
                else window.scrollTo({ top: 0 });
              } else {
                const target = document.querySelector(href);
                if (target) {
                  if (smoother) smoother.scrollTo(target, false);
                  else target.scrollIntoView();
                }
              }
              ScrollTrigger.refresh();
            } catch (e) {
              console.warn('[PageTransition] callback error:', e);
            }
          },
          null,
          null,
          0.7,
        );

        // Phase 4: Circle collapse (starts after text animation finishes at 1.25s)
        tl.to(
          ptWipe,
          {
            clipPath: `circle(0px at ${pos})`,
            duration: 0.3,
            ease: 'power2.inOut',
          },
          1.25,
        );

        // Phase 5: Text fade out (starts after text animation finishes)
        tl.to(ptBrand, { autoAlpha: 0, duration: 0.2 }, 1.25);

        // Phase 6: Hide overlay after out animations
        tl.set(ptOverlay, { autoAlpha: 0, pointerEvents: 'none' }, 1.55);
      };
    </script>
  </body>
</html>
