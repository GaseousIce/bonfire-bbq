---
import '../styles/global.css';
import LoadingScreen from '../components/LoadingScreen.astro';
import Navbar from '../components/Navbar.astro';
import PageTransition from '../components/PageTransition.astro';
import { getImage } from 'astro:assets';
import { heroTandoor } from '../assets/images';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Bonfire Barbecue | Indian Coal & Clay Oven | Tandoor & Grill Craft',
  description = 'Experience the primal art of clay tandoors, open-fire sigree kebabs, and slow-steamed biryani. A premium, cinematic Indian culinary story.',
} = Astro.props;

const heroImage = await getImage({
  src: heroTandoor,
  format: 'webp',
  width: 1920,
  quality: 82,
});
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />

    <!-- Preconnect hints for Google Fonts — saves 200-500ms font TTFB -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Space+Grotesk:wght@400;500;700&family=Space+Mono:wght@400;700&family=Newsreader:ital,opsz,wght@1,6..72,400&display=swap"
    />

    <!-- Preconnect for Unsplash images (Hero + About sections) -->
    <link rel="preconnect" href="https://images.unsplash.com" />

    <!-- Preload hero image (WebP via getImage — avoids preloading the 776 KB source PNG) -->
    <link rel="preload" href={heroImage.src} as="image" type="image/webp" fetchpriority="high" />

    <!-- Primary Meta Tags -->
    <title>{title}</title>
    <meta name="title" content={title} />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />

    <style>
      /* Hide scrollbar for clean presentation but allow scrolling */
      html {
        scrollbar-width: thin;
        scrollbar-color: #313131 #131313;
      }

      /* Promote smooth-wrapper/content to compositor layers on desktop where ScrollSmoother is active */
      @media (min-width: 768px) {
        #smooth-wrapper,
        #smooth-content {
          will-change: transform;
        }
      }

      /* Webkit scrollbar customization */
      ::-webkit-scrollbar {
        width: 6px;
      }
      ::-webkit-scrollbar-track {
        background: #131313;
      }
      ::-webkit-scrollbar-thumb {
        background: #313131;
        border-radius: 3px;
      }
      ::-webkit-scrollbar-thumb:hover {
        background: #3cffd0;
      }
    </style>
  </head>
  <body
    class="bg-canvas-black text-hazard-white selection:bg-brand-mint selection:text-canvas-black font-sans antialiased overflow-x-hidden"
  >
    <LoadingScreen />
    <Navbar />
    <div id="smooth-wrapper">
      <div id="smooth-content">
        <slot />
      </div>
    </div>
    <PageTransition />
    <script>
      import { gsap } from 'gsap';
      import { ScrollTrigger } from 'gsap/ScrollTrigger';
      import { ScrollSmoother } from 'gsap/ScrollSmoother';
      import { SplitText } from 'gsap/SplitText';

      // Extend Window so TypeScript recognises global helpers
      declare global {
        interface Window {
          __smoother?: ScrollSmoother;
          __pageTransition?: (href: string, originX?: number, originY?: number) => void;
          __ptSplit?: any;
          __ptCharsTween?: any;
        }
      }

      gsap.registerPlugin(ScrollTrigger, ScrollSmoother, SplitText);

      const isMobile = window.innerWidth < 768;

      if (!isMobile) {
        ScrollTrigger.normalizeScroll(true);
        window.__smoother = ScrollSmoother.create({
          wrapper: '#smooth-wrapper',
          content: '#smooth-content',
          smooth: 0.6,
        });
      }
      requestAnimationFrame(() => ScrollTrigger.refresh());

      // ── Page transition orchestration ──────────────────────────────
      let _transitionActive = false;

      window.__pageTransition = (href: string, originX?: number, originY?: number): void => {
        if (_transitionActive) return;
        _transitionActive = true;

        const ptOverlay = document.getElementById('page-transition') as HTMLElement | null;
        const ptWipe = document.getElementById('pt-wipe') as HTMLElement | null;
        const ptBrand = document.getElementById('pt-brand') as HTMLElement | null;
        const smoother = window.__smoother;
        if (!ptOverlay || !ptWipe || !ptBrand) {
          _transitionActive = false;
          return;
        }

        // Default to centre if no coordinates
        const cx = originX !== undefined ? originX : window.innerWidth / 2;
        const cy = originY !== undefined ? originY : window.innerHeight / 2;

        // Max radius to cover full viewport from any click point (viewport diagonal)
        const maxRadius = Math.sqrt(window.innerWidth * window.innerWidth + window.innerHeight * window.innerHeight);

        // Position string for clip-path (shared between start and end states)
        const pos = `${cx}px ${cy}px`;

        // Reset wipe: tiny circle at click point
        gsap.set(ptWipe, { clipPath: `circle(0px at ${pos})` });

        const tl = gsap.timeline({
          onComplete: () => {
            tl.kill();
            _transitionActive = false;
          },
          onInterrupt: () => { _transitionActive = false; }
        });

        // Phase 1: Show overlay + expand circle
        tl.set(ptOverlay, { pointerEvents: 'auto' });
        tl.to(ptOverlay, { autoAlpha: 1, duration: 0.1 }, 0);
        tl.to(ptWipe, {
          clipPath: `circle(${maxRadius}px at ${pos})`,
          duration: 1.0,
          ease: 'power2.inOut',
        }, 0);

        // Phase 3: SplitText char masking via GSAP mask property
        // (brand text becomes visible only after SplitText chars are ready — avoids unsplit flash)
        tl.call(() => {
          try {
            const split = new SplitText(ptBrand!, { type: 'chars', mask: 'chars' });
            (window as any).__ptSplit = split;
            (window as any).__ptCharsTween = gsap.from(split.chars, {
              yPercent: 100,
              duration: 0.6,
              stagger: 0.05,
              ease: 'power3.out',
            });
            // Make text visible now that SplitText chars are in place
            gsap.set(ptBrand, { autoAlpha: 1 });
          } catch (e) {
            console.warn('[PageTransition] SplitText error:', e);
          }
        }, null, null, 0.85);

        // Phase 4: Navigate + revert SplitText
        tl.call(() => {
          try {
            if (href === '#hero') {
              if (smoother) smoother.scrollTo(0, false);
              else window.scrollTo({ top: 0 });
            } else {
              const target = document.querySelector(href);
              if (target) {
                if (smoother) {
                  smoother.scrollTo(target, false);
                } else {
                  target.scrollIntoView();
                }
              }
            }
            ScrollTrigger.refresh();

            const charsTween = (window as any).__ptCharsTween;
            if (typeof charsTween?.kill === 'function') charsTween.kill();
            (window as any).__ptCharsTween = null;

            const split = (window as any).__ptSplit;
            if (split) {
              split.revert();
              (window as any).__ptSplit = null;
            }
          } catch (e) {
            console.warn('[PageTransition] callback error:', e);
          }
        }, null, null, 2.0);

        // Phase 5: Text fade out
        tl.to(ptBrand, { autoAlpha: 0, duration: 0.2 }, 2.2);

        // Phase 6: Circle collapses back to click position
        tl.to(ptWipe, {
          clipPath: `circle(0px at ${pos})`,
          duration: 0.5,
          ease: 'power2.inOut',
        }, 2.5);

        // Phase 7: Hide overlay + disable pointer events
        tl.set(ptOverlay, { autoAlpha: 0, pointerEvents: 'none' }, 3.5);
      };
    </script>
  </body>
</html>
