---
const timelineEvents = [
  {
    time: "08:00",
    tag: "SPICE BLENDING",
    title: "Whole Aromatic Roasting",
    desc: "We dry-roast and hand-grind cardamom, black pepper, cloves, and star anise in small batches. No pre-made masalas are ever permitted near our kitchen.",
    type: "slate"
  },
  {
    time: "11:00",
    tag: "TANDOOR FIRES",
    title: "Clay Oven Heating",
    desc: "Our clay tandoors are fueled with premium hardwood charcoal, building an intense radiant heat bed of up to 900°F.",
    type: "mint" // Saturated accent card (Jelly Mint)
  },
  {
    time: "14:00",
    tag: "MARINATION",
    title: "The Double Coating",
    desc: "Meats are subjected to two rounds of marination: first in fresh lime and ginger-garlic, then in a rich spiced hung curd and cold-pressed mustard oil.",
    type: "slate"
  },
  {
    time: "18:00",
    tag: "SIGREE IGNITION",
    title: "Open-Air Grill Firing",
    desc: "The open charcoal sigrees are brought to life, establishing a glowing bed of coal embers for skewering our signature kebabs.",
    type: "purple" // Saturated accent card (Ultraviolet)
  },
  {
    time: "21:00",
    tag: "DUM STEAMING",
    title: "Claypot Slow Simmer",
    desc: "Our signature biryanis are sealed with dough in copper handis, slow-steaming over dying coals to lock in every aromatic note.",
    type: "slate"
  }
];
---

<section id="about" class="about-section relative w-full min-h-screen bg-canvas-black py-24 overflow-hidden border-t border-white/5">
  <!-- Drifting Background Accent Elements -->
  <div class="absolute top-[10%] right-[5%] text-[15vw] font-display font-black text-white/3 select-none pointer-events-none tracking-wider text-right uppercase z-0">
    COAL & TANDOOR
  </div>
  
  <div class="max-w-7xl mx-auto px-6 md:px-12 relative z-10">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-16 items-start">
      
      <!-- Left Column: StoryStream Timeline (5 Cols) -->
      <div class="lg:col-span-7 relative flex flex-col pl-4 md:pl-12 timeline-container">
        <!-- Vertical Timeline Spine -->
        <div class="absolute left-4 md:left-6 top-4 bottom-4 w-[1px] border-l border-dashed border-brand-purple/60 z-0">
          <!-- Active spine line that fills up on scroll -->
          <div class="timeline-progress-line absolute top-0 left-[-1px] w-[3px] h-0 bg-brand-mint origin-top"></div>
        </div>

        <!-- Section eyebrow and title -->
        <div class="mb-12 z-10">
          <span class="text-brand-mint font-mono text-xs uppercase tracking-[2px] block mb-2">OUR TIMELINE</span>
          <h2 class="font-display text-5xl md:text-7xl uppercase leading-none font-black text-hazard-white tracking-tight">
            THE STORYSTREAM
          </h2>
        </div>

        <!-- Timeline Cards -->
        <div class="flex flex-col gap-8 w-full z-10">
          {timelineEvents.map((event) => (
            <div class="relative flex flex-col md:flex-row gap-4 md:gap-8 items-start timeline-item">
              <!-- Spine Dot (centered on the spine line) -->
              <div class="absolute left-[-6px] md:left-[-30px] top-2.5 w-3 h-3 rounded-full border border-brand-purple/60 bg-canvas-black z-20 timeline-dot"></div>

              <!-- Left Rail Timestamp -->
              <div class="flex items-center gap-3 md:w-20 md:flex-shrink-0 md:justify-end text-left md:text-right font-mono text-[11px] font-bold text-brand-mint tracking-[1.5px] uppercase pt-1 timeline-time">
                <span>{event.time}</span>
              </div>

              <!-- Content Card -->
              <div class={`timeline-card w-full p-6 md:p-8 rounded-[20px] border transition-all duration-300 group cursor-default relative overflow-hidden
                ${event.type === 'mint' ? 'bg-brand-mint text-canvas-black border-transparent' : 
                  event.type === 'purple' ? 'bg-brand-purple text-hazard-white border-transparent' : 
                  'bg-surface-slate text-hazard-white border-white/10 hover:border-white/20'}`}
              >
                <div class="flex items-baseline justify-between mb-3">
                  <span class={`font-mono text-[10px] uppercase tracking-[1.5px] font-semibold 
                    ${event.type === 'mint' ? 'text-canvas-black/70' : 'text-brand-mint'}`}>
                    {event.tag}
                  </span>
                </div>
                <h3 class={`font-sans text-xl md:text-2xl font-bold tracking-tight mb-2 group-hover:text-link-blue transition-colors duration-180
                  ${event.type === 'mint' ? 'text-canvas-black' : 'text-hazard-white'}`}>
                  {event.title}
                </h3>
                <p class={`text-xs md:text-sm font-sans leading-relaxed
                  ${event.type === 'mint' ? 'text-canvas-black/80' : 
                    event.type === 'purple' ? 'text-white/80' : 'text-hazard-white/70'}`}>
                  {event.desc}
                </p>
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- Right Column: Layered Parallax Imagery (5 Cols + Offset) -->
      <div class="lg:col-span-5 lg:sticky lg:top-24 flex flex-col gap-12 mt-12 lg:mt-24">
        <!-- Floating Text Card (Philosophical Eyebrow) -->
        <div class="border border-white/10 rounded-[20px] p-6 bg-surface-slate flex flex-col gap-4 parallax-text z-20">
          <span class="font-mono text-[10px] uppercase tracking-[2px] text-brand-mint">THE FIRE PHILOSOPHY</span>
          <p class="font-serif italic text-base md:text-lg text-hazard-white leading-relaxed">
            "We do not cook with gas. We do not cook with electricity. We cook with hand-built clay tandoors, open charcoal sigrees, and freshly ground spices. The fire is the ancient heartbeat of Indian kitchen."
          </p>
        </div>

        <!-- Overlapping Parallax Images Container -->
        <div class="relative w-full aspect-[4/5] max-w-[400px] mx-auto z-10">
          <!-- Back layer image (Log pile) -->
          <div class="absolute top-[10%] left-0 w-[70%] aspect-square rounded-[20px] overflow-hidden border border-image-frame bg-canvas-black image-layer-back">
            <img 
              src="https://images.unsplash.com/photo-1546964124-0cce460f38ef?auto=format&fit=crop&w=600&q=80" 
              alt="Hardwood logs for smoking"
              class="w-full h-full object-cover filter brightness-50 contrast-125"
              loading="lazy"
            />
          </div>

          <!-- Front layer image (Grill chef) -->
          <div class="absolute bottom-0 right-0 w-[75%] aspect-[4/5] rounded-[24px] overflow-hidden border border-brand-mint/30 bg-canvas-black image-layer-front">
            <img 
              src="https://images.unsplash.com/photo-1565299624946-b28f40a0ae38?auto=format&fit=crop&w=600&q=80" 
              alt="Chef grilling steak"
              class="w-full h-full object-cover filter brightness-85 contrast-110"
              loading="lazy"
            />
          </div>
        </div>
      </div>

    </div>
  </div>
</section>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  document.addEventListener('DOMContentLoaded', () => {
    const timelineItems = gsap.utils.toArray('.timeline-item') as HTMLElement[];

    if (timelineItems.length > 0) {
      // 1. Spine Progress Line Animation
      const firstItem = timelineItems[0];
      const lastItem = timelineItems[timelineItems.length - 1];

      gsap.fromTo('.timeline-progress-line', 
        { height: '0%' },
        {
          height: '100%',
          ease: 'none',
          scrollTrigger: {
            trigger: '.timeline-container',
            start: () => `top+=${firstItem.offsetTop} 90%`,
            end: () => `top+=${lastItem.offsetTop} 55%`,
            scrub: true,
            invalidateOnRefresh: true,
          }
        }
      );

      // 2. Interactive Scroll-Driven Reveal for Cards, Timestamps, and Dots
      timelineItems.forEach((item) => {
        const card = item.querySelector('.timeline-card');
        const dot = item.querySelector('.timeline-dot');
        const time = item.querySelector('.timeline-time');

        // Responsive horizontal slide offset based on window size
        const isDesktop = window.innerWidth >= 768;
        const startX = isDesktop ? -100 : -40;

        const itemTl = gsap.timeline({
          scrollTrigger: {
            trigger: item,
            start: 'top 90%',
            end: 'top 55%',
            scrub: true, // Bind directly and instantaneously to scroll speed
            invalidateOnRefresh: true,
          }
        });

        if (card) {
          itemTl.fromTo(card,
            { opacity: 0, x: startX, scale: 0.9 },
            { opacity: 1, x: 0, scale: 1, ease: 'none', duration: 1 },
            0
          );
        }

        if (dot) {
          itemTl.fromTo(dot,
            { 
              backgroundColor: '#131313', 
              borderColor: 'rgba(82, 0, 255, 0.6)', 
              boxShadow: '0 0 0px rgba(60, 255, 208, 0)'
            },
            { 
              backgroundColor: '#3cffd0', 
              borderColor: '#3cffd0', 
              boxShadow: '0 0 10px rgba(60, 255, 208, 0.8)',
              ease: 'none',
              duration: 1
            },
            0
          );
        }

        if (time) {
          itemTl.fromTo(time,
            { opacity: 0.3 },
            { opacity: 1, ease: 'none', duration: 1 },
            0
          );
        }
      });
    }

    // 3. Parallax Image Scrolling (Layered Depth)
    const backImage = document.querySelector('.image-layer-back');
    const frontImage = document.querySelector('.image-layer-front');
    const textCard = document.querySelector('.parallax-text');

    let mm = gsap.matchMedia();

    mm.add("(min-width: 1024px)", () => {
      // Back image scrolls slower upwards
      gsap.fromTo(backImage, 
        { y: -30 },
        {
          y: 60,
          scrollTrigger: {
            trigger: '.about-section',
            start: 'top bottom',
            end: 'bottom top',
            scrub: true
          }
        }
      );

      // Front image scrolls faster upwards (foreground pop)
      gsap.fromTo(frontImage, 
        { y: 50 },
        {
          y: -80,
          scrollTrigger: {
            trigger: '.about-section',
            start: 'top bottom',
            end: 'bottom top',
            scrub: true
          }
        }
      );

      // Text card floats at an offset
      gsap.fromTo(textCard, 
        { y: 10 },
        {
          y: -40,
          scrollTrigger: {
            trigger: '.about-section',
            start: 'top bottom',
            end: 'bottom top',
            scrub: true
          }
        }
      );
    });
  });
</script>
