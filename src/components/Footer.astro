---
const currentYear = new Date().getFullYear();
---

<footer
  class="relative w-full bg-canvas-black border-t border-white/10 pt-20 pb-8 overflow-hidden z-10"
>
  <div class="max-w-7xl mx-auto px-6 md:px-12 flex flex-col gap-16">
    <!-- Top Footer Columns -->
    <div class="grid grid-cols-1 md:grid-cols-12 gap-12">
      <!-- Description col -->
      <div class="md:col-span-5 flex flex-col gap-4">
        <span
          class="logo-icon w-8 h-8 rounded-lg bg-brand-mint flex items-center justify-center font-display text-canvas-black text-xl font-black"
          >B</span
        >
        <p class="font-serif italic text-base text-hazard-white/70 leading-relaxed max-w-sm">
          "Indian coal, clay ovens, and raw cooking mastery. Crafting premium tandoori, kebabs, and
          slow-steamed biryanis daily in the heart of the city."
        </p>
      </div>

      <!-- Links col 1 -->
      <div class="md:col-span-2 flex flex-col gap-4">
        <span class="font-mono text-[10px] uppercase tracking-[2px] text-brand-mint font-semibold"
          >NAVIGATION</span
        >
        <ul class="flex flex-col gap-2 text-xs font-mono uppercase tracking-[1px]">
          <li>
            <a
              href="#hero"
              class="footer-nav-link text-hazard-white hover:text-link-blue transition-colors duration-150"
              >Top</a
            >
          </li>
          <li>
            <a
              href="#about"
              class="footer-nav-link text-hazard-white hover:text-link-blue transition-colors duration-150"
              >Timeline</a
            >
          </li>
          <li>
            <a
              href="#dishes"
              class="footer-nav-link text-hazard-white hover:text-link-blue transition-colors duration-150"
              >Menu</a
            >
          </li>
          <li>
            <a
              href="#gallery"
              class="footer-nav-link text-hazard-white hover:text-link-blue transition-colors duration-150"
              >Atmosphere</a
            >
          </li>
          <li>
            <a
              href="#reserve"
              class="footer-nav-link text-hazard-white hover:text-link-blue transition-colors duration-150"
              >Reservations</a
            >
          </li>
        </ul>
      </div>

      <!-- Links col 2 (Location / Contact) -->
      <div class="md:col-span-3 flex flex-col gap-4">
        <span class="font-mono text-[10px] uppercase tracking-[2px] text-brand-mint font-semibold"
          >THE HEARTH</span
        >
        <address
          class="not-italic flex flex-col gap-2 font-mono text-[11px] text-secondary-text uppercase tracking-[1px] leading-relaxed"
        >
          <p>Police Line Square, OT Rd</p>
          <p>Balasore, Isamnagar, Odisha 756001, India</p>
          <p>Phone: +91 99990 39220</p>
          <p>Email: hello@bonfire-bbq.com</p>
        </address>
      </div>

      <!-- Links col 3 (Hours) -->
      <div class="md:col-span-2 flex flex-col gap-4">
        <span class="font-mono text-[10px] uppercase tracking-[2px] text-brand-mint font-semibold"
          >SERVICE HOURS</span
        >
        <div
          class="flex flex-col gap-2 font-mono text-[11px] text-secondary-text uppercase tracking-[1px]"
        >
          <p>Wed – Sun: 4pm – Late</p>
          <p>Mon – Tue: Pit Closed</p>
        </div>
      </div>
    </div>

    <!-- Massive Editorial Wordmark -->
    <div
      class="border-t border-white/5 pt-10 select-none overflow-hidden flex justify-center items-center"
    >
      <span
        class="font-display text-[min(24vw,280px)] text-center leading-[0.75] font-black text-white/5 tracking-wide w-full block"
      >
        BONFIRE
      </span>
    </div>

    <!-- Bottom Copyright -->
    <div
      class="flex flex-col sm:flex-row justify-between items-center gap-4 text-center font-mono text-[9px] text-secondary-text uppercase tracking-[1.5px] border-t border-white/5 pt-8"
    >
      <div>
        <span>&copy; {currentYear} BONFIRE BARBECUE. ALL HEARTHS RESERVED.</span>
      </div>
      <div class="flex gap-6">
        <button
          type="button"
          class="legal-modal-trigger hover:text-link-blue transition-colors cursor-pointer"
          data-modal="privacy">Privacy Policy</button
        >
        <button
          type="button"
          class="legal-modal-trigger hover:text-link-blue transition-colors cursor-pointer"
          data-modal="terms">Terms of Service</button
        >
      </div>
    </div>
  </div>
</footer>

<!-- Legal Modal Dialog -->
<div
  id="legal-modal"
  class="fixed inset-0 z-50 bg-canvas-black/90 backdrop-blur-md flex items-center justify-center p-4 sm:p-6 opacity-0 pointer-events-none transition-opacity duration-300"
  aria-hidden="true"
  role="dialog"
  aria-modal="true"
>
  <div
    class="bg-canvas-black border border-white/10 rounded-2xl max-w-2xl w-full max-h-[85vh] flex flex-col shadow-2xl overflow-hidden relative transform scale-95 transition-transform duration-300"
    id="legal-modal-card"
  >
    <!-- Modal Header -->
    <div
      class="flex items-center justify-between px-6 py-5 border-b border-white/10 bg-white/[0.02]"
    >
      <div class="flex items-center gap-3">
        <span class="w-2 h-2 rounded-full bg-brand-mint"></span>
        <h3
          id="legal-modal-title"
          class="font-mono text-xs uppercase tracking-[2px] text-brand-mint font-bold"
        >
          HEARTH CHARTER
        </h3>
      </div>
      <button
        type="button"
        id="legal-modal-close"
        class="text-hazard-white/60 hover:text-brand-mint p-1 rounded-lg transition-colors cursor-pointer text-base font-mono leading-none"
        aria-label="Close dialog"
      >
        ✕
      </button>
    </div>

    <!-- Modal Body -->
    <div
      id="legal-modal-content"
      class="p-6 overflow-y-auto space-y-4 font-sans text-xs text-hazard-white/80 leading-relaxed max-h-[60vh]"
    >
    </div>

    <!-- Modal Footer -->
    <div class="px-6 py-4 border-t border-white/10 bg-white/[0.02] flex justify-end">
      <button
        type="button"
        id="legal-modal-done"
        class="font-mono text-[11px] uppercase tracking-[1.5px] font-bold px-6 py-2.5 rounded-full bg-brand-mint text-canvas-black hover:bg-white transition-colors cursor-pointer"
      >
        Acknowledge &amp; Close
      </button>
    </div>
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const footerCtrl = new AbortController();
    const navLinks = document.querySelectorAll('.footer-nav-link');

    navLinks.forEach((footerNavLink) => {
      footerNavLink.addEventListener('click', (clickEvent) => {
        clickEvent.preventDefault();
        const mouseEvent = clickEvent as MouseEvent;
        let cx = mouseEvent.clientX;
        let cy = mouseEvent.clientY;
        const el = clickEvent.currentTarget as HTMLElement | null;
        // Keyboard clicks produce (0,0) with detail=0 — use element centre instead
        if (cx === 0 && cy === 0 && (clickEvent as MouseEvent).detail === 0 && el) {
          const rect = el.getBoundingClientRect();
          cx = rect.left + rect.width / 2;
          cy = rect.top + rect.height / 2;
        }
        const href = footerNavLink.getAttribute('href');
        if (href && window.__pageTransition) window.__pageTransition(href, cx, cy);
      });
    });

    // Legal Modal Functionality
    const legalModal = document.getElementById('legal-modal');
    const legalModalCard = document.getElementById('legal-modal-card');
    const legalModalTitle = document.getElementById('legal-modal-title');
    const legalModalContent = document.getElementById('legal-modal-content');
    const legalModalClose = document.getElementById('legal-modal-close');
    const legalModalDone = document.getElementById('legal-modal-done');
    const modalTriggers = document.querySelectorAll('.legal-modal-trigger');

    // Move modal element to document.body so fixed positioning is relative to window viewport (outside smooth-content container)
    if (legalModal) {
      document.body.appendChild(legalModal);
    }

    type LegalParagraph = { text: string; bold: boolean };

    const legalTexts: Record<string, { title: string; paragraphs: LegalParagraph[] }> = {
      privacy: {
        title: 'PRIVACY POLICY — HEARTH DATA CHARTER',
        paragraphs: [
          { text: '1. Hearth Commitment', bold: true },
          { text: 'At Bonfire Barbecue, we protect your personal information with the same dedication we bring to our open-fire cooking. This charter outlines how we manage your details when reserving seating or contacting our pit masters.', bold: false },
          { text: '2. Information Collection', bold: true },
          { text: 'We collect only essential details required to manage reservations and seating preferences, including your name, email address, phone number, party size, and dietary notes.', bold: false },
          { text: '3. Culinary Analytics', bold: true },
          { text: 'We analyze anonymized visit metrics to optimize seasonal menu rotation and maintain kitchen pacing during peak dining hours.', bold: false },
          { text: '4. Data Protection', bold: true },
          { text: 'Your details are securely encrypted. We strictly never sell, rent, or trade your personal information to third parties.', bold: false },
        ],
      },
      terms: {
        title: 'TERMS OF SERVICE — DINING PROTOCOL',
        paragraphs: [
          { text: '1. Reservation Holding Pacing', bold: true },
          { text: 'Tables are held for up to 15 minutes past scheduled booking times. Due to live coal kitchen preparation, late arrivals may experience adjusted table seating or staggered dish timing.', bold: false },
          { text: '2. Pitmaster Tasting & Dietary Notes', bold: true },
          { text: 'Our dishes highlight traditional tandoori roasting and authentic spice blends. Please inform your server or note during booking of any severe food allergies.', bold: false },
          { text: '3. Party Cancellations', bold: true },
          { text: 'For parties of 6 or more, we kindly request 24 hours advance cancellation notice to assist our culinary team with fresh daily sourcing.', bold: false },
          { text: '4. Atmosphere & Conduct', bold: true },
          { text: 'Bonfire Barbecue preserves a cinematic, immersive hearth environment. Guests are asked to observe courteous dining etiquette near live charcoal stations.', bold: false },
        ],
      },
    };

    function renderLegalContent(container: HTMLElement, paragraphs: LegalParagraph[]): void {
      container.textContent = '';
      for (let i = 0; i < paragraphs.length; i++) {
        const p = document.createElement('p');
        const classes = ['text-hazard-white'];
        if (paragraphs[i].bold) classes.push('font-semibold');
        if (i > 0 && paragraphs[i].bold) classes.push('pt-2');
        p.className = classes.join(' ');
        p.textContent = paragraphs[i].text;
        container.appendChild(p);
      }
    }

    const openModal = (policyType: string) => {
      const policyDetails = legalTexts[policyType];
      if (
        !policyDetails ||
        !legalModal ||
        !legalModalTitle ||
        !legalModalContent ||
        !legalModalCard
      )
        return;

      legalModalTitle.textContent = policyDetails.title;
      renderLegalContent(legalModalContent, policyDetails.paragraphs);

      legalModal.classList.remove('opacity-0', 'pointer-events-none');
      legalModal.classList.add('opacity-100', 'pointer-events-auto');
      legalModal.setAttribute('aria-hidden', 'false');

      legalModalCard.classList.remove('scale-95');
      legalModalCard.classList.add('scale-100');

      // Lock background scrolling and pause ScrollSmoother
      document.body.style.overflow = 'hidden';
      const smoother = window.__smoother;
      if (smoother) smoother.paused(true);
    };

    const closeModal = () => {
      if (!legalModal || !legalModalCard) return;
      legalModal.classList.remove('opacity-100', 'pointer-events-auto');
      legalModal.classList.add('opacity-0', 'pointer-events-none');
      legalModal.setAttribute('aria-hidden', 'true');

      legalModalCard.classList.remove('scale-100');
      legalModalCard.classList.add('scale-95');

      // Restore background scrolling and unpause ScrollSmoother
      document.body.style.overflow = '';
      const smoother = window.__smoother;
      if (smoother) smoother.paused(false);
    };

    modalTriggers.forEach((triggerButton) => {
      triggerButton.addEventListener('click', (clickEvent) => {
        clickEvent.preventDefault();
        const modalType = (triggerButton as HTMLElement).getAttribute('data-modal');
        if (modalType) openModal(modalType);
      });
    });

    if (legalModalClose) legalModalClose.addEventListener('click', closeModal);
    if (legalModalDone) legalModalDone.addEventListener('click', closeModal);

    if (legalModal) {
      legalModal.addEventListener('click', (clickEvent) => {
        if (clickEvent.target === legalModal) closeModal();
      });
    }

    document.addEventListener(
      'keydown',
      (keyboardEvent) => {
        if (keyboardEvent.key === 'Escape' && legalModal?.classList.contains('opacity-100')) {
          closeModal();
        }
      },
      { signal: footerCtrl.signal },
    );
  });
</script>
