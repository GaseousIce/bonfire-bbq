---
const currentYear = new Date().getFullYear();
const monthNames = [
  'January',
  'February',
  'March',
  'April',
  'May',
  'June',
  'July',
  'August',
  'September',
  'October',
  'November',
  'December',
];
const months = monthNames.map((name, i) => ({ value: String(i), label: name.substring(0, 3) }));
const years = Array.from({ length: 5 }, (_, i) => ({
  value: String(currentYear + i),
  label: String(currentYear + i),
}));
---

<div class="flex flex-col gap-2">
  <label
    for="date-trigger"
    class="font-mono text-[10px] uppercase tracking-[1.5px] text-hazard-white/80">Date</label
  >
  <div class="custom-datetime relative">
    <input type="hidden" name="date" value="" />
    <button
      type="button"
      id="date-trigger"
      class="custom-dt-trigger bg-canvas-black border border-white/20 text-sm font-sans text-hazard-white px-4 py-3 rounded-[12px] focus:outline-none focus:border-brand-mint focus:ring-1 focus:ring-brand-purple transition-[border-color,box-shadow] duration-150 w-full flex items-center justify-between cursor-pointer"
      role="combobox"
      aria-expanded="false"
      aria-label="Date"
    >
      <span class="custom-dt-label text-secondary-text">Select date</span>
      <svg
        class="w-3.5 h-3.5 text-hazard-white/60 flex-shrink-0"
        width="14"
        height="14"
        viewBox="0 0 14 14"
        fill="none"
      >
        <rect x="1" y="2" width="12" height="11" rx="1.5" stroke="currentColor" stroke-width="1.2"
        ></rect>
        <path d="M1 5h12" stroke="currentColor" stroke-width="1.2"></path>
        <path d="M4.5 1v2M9.5 1v2" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"
        ></path>
      </svg>
    </button>

    <!-- Calendar panel -->
    <div
      class="custom-dt-panel absolute top-full left-0 right-0 z-30 mt-1.5 bg-canvas-black border border-white/10 rounded-[16px] shadow-2xl min-w-[280px] sm:min-w-[300px]"
      style="display: none; opacity: 0; transform: translateY(-6px);"
    >
      <!-- Month header -->
      <div class="flex items-center justify-between px-5 pt-4 pb-1.5">
        <button
          type="button"
          class="dt-month-prev text-hazard-white/50 hover:text-brand-mint transition-colors text-xl leading-none p-1 cursor-pointer bg-transparent border-none"
          aria-label="Previous month">&#8249;</button
        >
        <div class="flex items-center gap-1.5">
          <!-- Month Custom Dropdown -->
          <div class="custom-select dt-month-select relative" data-name="month">
            <button
              type="button"
              class="custom-select-trigger bg-canvas-black border border-white/10 text-sm font-sans text-hazard-white px-2 py-1.5 rounded-[8px] focus:outline-none focus:border-brand-mint cursor-pointer hover:border-white/20 transition-colors flex items-center gap-1.5"
              aria-expanded="false"
            >
              <span class="custom-select-label">Jan</span>
              <svg
                class="custom-select-arrow w-2 h-1.5 text-hazard-white/60"
                viewBox="0 0 12 8"
                fill="none"
                style="transform-origin: center;"
              >
                <path
                  d="M1 1l5 5 5-5"
                  stroke="currentColor"
                  stroke-width="1.5"
                  stroke-linecap="round"></path>
              </svg>
            </button>
            <div
              class="custom-select-options grid grid-cols-3 gap-1 p-1.5 absolute top-full -left-6 z-40 mt-1 bg-canvas-black border border-white/10 rounded-[12px] shadow-2xl w-[180px]"
              style="display: none; opacity: 0; transform: translateY(-6px);"
            >
              {
                months.map((m) => (
                  <button
                    type="button"
                    class="custom-select-option w-full text-center py-2 text-sm font-sans text-hazard-white hover:bg-white/10 hover:text-brand-mint transition-colors duration-150 rounded-[8px] cursor-pointer"
                    data-value={m.value}
                  >
                    {m.label}
                  </button>
                ))
              }
            </div>
          </div>

          <!-- Year Custom Dropdown -->
          <div class="custom-select dt-year-select relative" data-name="year">
            <button
              type="button"
              class="custom-select-trigger bg-canvas-black border border-white/10 text-sm font-sans text-hazard-white px-2 py-1.5 rounded-[8px] focus:outline-none focus:border-brand-mint cursor-pointer hover:border-white/20 transition-colors flex items-center gap-1.5"
              aria-expanded="false"
            >
              <span class="custom-select-label">{currentYear}</span>
              <svg
                class="custom-select-arrow w-2 h-1.5 text-hazard-white/60"
                viewBox="0 0 12 8"
                fill="none"
                style="transform-origin: center;"
              >
                <path
                  d="M1 1l5 5 5-5"
                  stroke="currentColor"
                  stroke-width="1.5"
                  stroke-linecap="round"></path>
              </svg>
            </button>
            <div
              class="custom-select-options absolute top-full left-0 z-40 mt-1 bg-canvas-black border border-white/10 rounded-[8px] overflow-x-hidden shadow-2xl min-w-[70px] max-h-[240px] overflow-y-auto custom-scrollbar"
              style="display: none; opacity: 0; transform: translateY(-6px);"
            >
              {
                years.map((y) => (
                  <button
                    type="button"
                    class="custom-select-option w-full text-left px-3 py-2 text-sm font-sans text-hazard-white hover:bg-white/5 hover:text-brand-mint transition-colors duration-150 border-b border-white/5 last:border-b-0 cursor-pointer"
                    data-value={y.value}
                  >
                    {y.label}
                  </button>
                ))
              }
            </div>
          </div>
        </div>
        <button
          type="button"
          class="dt-month-next text-hazard-white/50 hover:text-brand-mint transition-colors text-xl leading-none p-1 cursor-pointer bg-transparent border-none"
          aria-label="Next month">&#8250;</button
        >
      </div>

      <!-- Day-of-week headers -->
      <div class="grid grid-cols-7 px-5 pb-1">
        <span class="text-center font-mono text-[9px] uppercase tracking-[1px] text-secondary-text"
          >Su</span
        >
        <span class="text-center font-mono text-[9px] uppercase tracking-[1px] text-secondary-text"
          >Mo</span
        >
        <span class="text-center font-mono text-[9px] uppercase tracking-[1px] text-secondary-text"
          >Tu</span
        >
        <span class="text-center font-mono text-[9px] uppercase tracking-[1px] text-secondary-text"
          >We</span
        >
        <span class="text-center font-mono text-[9px] uppercase tracking-[1px] text-secondary-text"
          >Th</span
        >
        <span class="text-center font-mono text-[9px] uppercase tracking-[1px] text-secondary-text"
          >Fr</span
        >
        <span class="text-center font-mono text-[9px] uppercase tracking-[1px] text-secondary-text"
          >Sa</span
        >
      </div>

      <!-- Day cells -->
      <div class="dt-days grid grid-cols-7 px-5 pb-4 gap-0.5"></div>
    </div>
  </div>
</div>

<style>
  .custom-scrollbar::-webkit-scrollbar {
    width: 4px;
  }
  .custom-scrollbar::-webkit-scrollbar-track {
    background: transparent;
  }
  .custom-scrollbar::-webkit-scrollbar-thumb {
    background: rgba(255, 255, 255, 0.15);
    border-radius: 4px;
  }
  .custom-scrollbar::-webkit-scrollbar-thumb:hover {
    background: rgba(255, 255, 255, 0.25);
  }
  .custom-scrollbar {
    scrollbar-width: thin;
    scrollbar-color: rgba(255, 255, 255, 0.15) transparent;
  }
</style>

<script>
  import { gsap } from 'gsap';
  import { initCustomDropdown } from '../../scripts/dropdown';

  document.addEventListener('DOMContentLoaded', () => {
    const ctrl = new AbortController();
    const dateTimeContainer = document.querySelector('.custom-datetime');
    if (!dateTimeContainer) return;

    const dateTimeTriggerButton = dateTimeContainer.querySelector(
      '.custom-dt-trigger',
    ) as HTMLElement;
    const calendarPanelElement = dateTimeContainer.querySelector('.custom-dt-panel') as HTMLElement;
    const dateTimeLabelElement = dateTimeContainer.querySelector('.custom-dt-label') as HTMLElement;
    const hiddenInput = dateTimeContainer.querySelector('input[type="hidden"]') as HTMLInputElement;
    const monthSelectElement = dateTimeContainer.querySelector('.dt-month-select') as HTMLElement;
    const yearSelectElement = dateTimeContainer.querySelector('.dt-year-select') as HTMLElement;
    const monthOptionsPanel = monthSelectElement.querySelector(
      '.custom-select-options',
    ) as HTMLElement;
    const monthLabelElement = monthSelectElement.querySelector(
      '.custom-select-label',
    ) as HTMLElement;
    const yearLabelElement = yearSelectElement.querySelector('.custom-select-label') as HTMLElement;
    const calendarDaysGrid = dateTimeContainer.querySelector('.dt-days') as HTMLElement;
    const previousMonthButton = dateTimeContainer.querySelector(
      '.dt-month-prev',
    ) as HTMLButtonElement;
    const nextMonthButton = dateTimeContainer.querySelector('.dt-month-next') as HTMLButtonElement;

    // Init month/year dropdowns
    initCustomDropdown(monthSelectElement, ctrl.signal);
    initCustomDropdown(yearSelectElement, ctrl.signal);

    let isCalendarOpen = false;
    let viewedMonth = new Date().getMonth();
    let viewedYear = new Date().getFullYear();
    let selectedDate: Date | null = null;

    const monthNames = [
      'January',
      'February',
      'March',
      'April',
      'May',
      'June',
      'July',
      'August',
      'September',
      'October',
      'November',
      'December',
    ];

    function updateMonthOptionsState() {
      const currentYear = new Date().getFullYear();
      const currentMonth = new Date().getMonth();
      const selectedYear = parseInt(yearSelectElement.dataset.value || String(currentYear), 10);
      const opts = monthOptionsPanel.querySelectorAll('.custom-select-option');
      opts.forEach((opt, idx) => {
        const isPast = selectedYear === currentYear && idx < currentMonth;
        (opt as HTMLButtonElement).disabled = isPast;
        opt.classList.toggle('opacity-30', isPast);
        opt.classList.toggle('cursor-not-allowed', isPast);
        opt.classList.toggle('hover:bg-white/10', !isPast);
        opt.classList.toggle('hover:text-brand-mint', !isPast);
      });
    }

    updateMonthOptionsState();

    monthSelectElement.addEventListener('change', () => {
      viewedMonth = parseInt(monthSelectElement.dataset.value || '0', 10);
      renderCalendar();
      if (monthNavTween) monthNavTween.kill();
      staggerCalendarDays();
    });

    yearSelectElement.addEventListener('change', () => {
      viewedYear = parseInt(yearSelectElement.dataset.value || '0', 10);
      updateMonthOptionsState();
      renderCalendar();
      if (monthNavTween) monthNavTween.kill();
      staggerCalendarDays();
    });

    let monthNavTween: gsap.core.Tween | null = null;

    function renderCalendar() {
      monthSelectElement.dataset.value = String(viewedMonth);
      yearSelectElement.dataset.value = String(viewedYear);
      monthLabelElement.textContent = monthNames[viewedMonth].substring(0, 3);
      yearLabelElement.textContent = String(viewedYear);

      const firstDay = new Date(viewedYear, viewedMonth, 1).getDay();
      const daysInMonth = new Date(viewedYear, viewedMonth + 1, 0).getDate();
      const today = new Date();
      const todayStart = new Date(today.getFullYear(), today.getMonth(), today.getDate());

      const isCurrentMonth = viewedMonth === today.getMonth() && viewedYear === today.getFullYear();
      previousMonthButton.disabled = isCurrentMonth;
      previousMonthButton.classList.toggle('opacity-25', isCurrentMonth);
      previousMonthButton.classList.toggle('cursor-not-allowed', isCurrentMonth);

      calendarDaysGrid.innerHTML = '';

      for (let dayIndex = 0; dayIndex < firstDay; dayIndex++) {
        const emptyCell = document.createElement('div');
        calendarDaysGrid.appendChild(emptyCell);
      }

      for (let dayOfMonth = 1; dayOfMonth <= daysInMonth; dayOfMonth++) {
        const dayButtonElement = document.createElement('button');
        dayButtonElement.type = 'button';
        dayButtonElement.className =
          'dt-day text-center font-sans text-sm w-full aspect-square rounded-[8px] flex items-center justify-center cursor-pointer transition-colors duration-150';
        dayButtonElement.textContent = String(dayOfMonth);

        const dateObj = new Date(viewedYear, viewedMonth, dayOfMonth);
        const isCurrentDay = dateObj.toDateString() === today.toDateString();
        const isSelectedDate =
          selectedDate && dateObj.toDateString() === selectedDate.toDateString();
        const isPastDate = dateObj < todayStart;

        if (isPastDate) {
          dayButtonElement.disabled = true;
          dayButtonElement.classList.add(
            'text-hazard-white/20',
            'opacity-25',
            'cursor-not-allowed',
          );
        } else if (isSelectedDate) {
          dayButtonElement.classList.add('bg-brand-mint', 'text-canvas-black', 'font-semibold');
        } else if (isCurrentDay) {
          dayButtonElement.classList.add('border', 'border-brand-mint/40', 'text-brand-mint');
        } else {
          dayButtonElement.classList.add(
            'text-hazard-white/80',
            'hover:bg-white/5',
            'hover:text-brand-mint',
          );
        }

        if (!isPastDate) {
          dayButtonElement.addEventListener('click', (clickEvent) => {
            clickEvent.stopPropagation();
            selectedDate = dateObj;
            renderCalendar();

            const monthShort = dateObj.toLocaleString('default', { month: 'short' });
            const day = dateObj.getDate();
            dateTimeLabelElement.textContent = `${monthShort} ${day}`;
            dateTimeLabelElement.classList.remove('text-secondary-text');

            const yyyy = dateObj.getFullYear();
            const mm = String(dateObj.getMonth() + 1).padStart(2, '0');
            const dd = String(dateObj.getDate()).padStart(2, '0');
            hiddenInput.value = `${yyyy}-${mm}-${dd}`;

            closeCalendarPanel();

            const dateSelectedEvent = new CustomEvent('bonfire:date-selected', {
              detail: { date: dateObj },
            });
            document.dispatchEvent(dateSelectedEvent);
          });
        }

        calendarDaysGrid.appendChild(dayButtonElement);
      }
    }

    const calendarPanelTween = gsap.fromTo(
      calendarPanelElement,
      { opacity: 0, y: -6 },
      {
        opacity: 1,
        y: 0,
        duration: 0.5,
        ease: 'elastic.out(1, 0.4)',
        easeReverse: 'power2.in',
        paused: true,
        onReverseComplete: () => {
          calendarPanelElement.style.display = 'none';
        },
      },
    );

    function staggerCalendarDays() {
      const dayButtons = calendarDaysGrid.querySelectorAll('.dt-day');
      if (dayButtons.length) {
        gsap.fromTo(
          dayButtons,
          { opacity: 0, y: 10, scale: 0.9 },
          {
            opacity: 1,
            y: 0,
            scale: 1,
            duration: 0.35,
            stagger: 0.025,
            ease: 'back.out(1.4)',
            clearProps: 'scale',
          },
        );
      }
    }

    function openCalendarPanel() {
      if (isCalendarOpen) return;
      isCalendarOpen = true;

      const event = new CustomEvent('bonfire:dropdown-opened', {
        detail: { target: dateTimeContainer },
      });
      document.dispatchEvent(event);

      dateTimeTriggerButton.setAttribute('aria-expanded', 'true');
      renderCalendar();
      calendarPanelElement.style.display = 'block';
      calendarPanelTween.restart();
      staggerCalendarDays();
    }

    function closeCalendarPanel() {
      if (!isCalendarOpen) return;
      isCalendarOpen = false;
      dateTimeTriggerButton.setAttribute('aria-expanded', 'false');
      calendarPanelTween.timeScale(2).reverse();
    }

    dateTimeTriggerButton.addEventListener('click', (clickEvent) => {
      clickEvent.stopPropagation();
      isCalendarOpen ? closeCalendarPanel() : openCalendarPanel();
    });

    previousMonthButton.addEventListener('click', (clickEvent) => {
      clickEvent.stopPropagation();
      const today = new Date();
      if (viewedMonth === today.getMonth() && viewedYear === today.getFullYear()) return;
      viewedMonth--;
      if (viewedMonth < 0) {
        viewedMonth = 11;
        viewedYear--;
      }
      renderCalendar();
      if (monthNavTween) monthNavTween.kill();
      monthNavTween = gsap.fromTo(
        calendarDaysGrid.querySelectorAll('.dt-day'),
        { opacity: 0, x: -10 },
        { opacity: 1, x: 0, duration: 0.3, stagger: 0.015, ease: 'power2.out', clearProps: 'x' },
      );
    });

    nextMonthButton.addEventListener('click', (clickEvent) => {
      clickEvent.stopPropagation();
      viewedMonth++;
      if (viewedMonth > 11) {
        viewedMonth = 0;
        viewedYear++;
      }
      renderCalendar();
      if (monthNavTween) monthNavTween.kill();
      monthNavTween = gsap.fromTo(
        calendarDaysGrid.querySelectorAll('.dt-day'),
        { opacity: 0, x: 10 },
        { opacity: 1, x: 0, duration: 0.3, stagger: 0.015, ease: 'power2.out', clearProps: 'x' },
      );
    });

    document.addEventListener(
      'click',
      (clickEvent) => {
        if (!dateTimeContainer.contains(clickEvent.target as Node) && isCalendarOpen) {
          closeCalendarPanel();
        }
      },
      { signal: ctrl.signal },
    );

    document.addEventListener(
      'bonfire:dropdown-opened',
      ((e: CustomEvent) => {
        if (isCalendarOpen && !dateTimeContainer.contains(e.detail.target as Node)) {
          closeCalendarPanel();
        }
      }) as EventListener,
      { signal: ctrl.signal },
    );

    renderCalendar();
  });
</script>
