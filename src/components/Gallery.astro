---
import { Image } from 'astro:assets';
import { galleryBiryani, gallerySigree, gallerySpices, galleryTandoor } from '../assets/images';

const galleryItems = [
  {
    id: 'h-01',
    tag: 'THE TANDOOR',
    title: '900°F Clay Oven',
    image: galleryTandoor,
    alt: 'Skewers of chicken roasting inside a glowing clay tandoor oven',
  },
  {
    id: 'h-02',
    tag: 'THE SIGREE',
    title: 'Coal-Fired Kebabs',
    image: gallerySigree,
    alt: 'Spicy chicken kebabs cooking over an open-air charcoal sigree grill',
  },
  {
    id: 'h-03',
    tag: 'THE MASALA',
    title: 'Stone-Ground Spices',
    image: gallerySpices,
    alt: 'Aromatic whole Indian spices being crushed on a stone mortar',
  },
  {
    id: 'h-04',
    tag: 'THE DUM HANDI',
    title: 'Slow-Steamed Biryani',
    image: galleryBiryani,
    alt: 'Dough-sealed clay handi pot cooking biryani over dying embers',
  },
];
---

<section
  id="gallery"
  class="gallery-pin-container relative w-full h-[250vh] bg-canvas-black overflow-x-hidden py-16 md:py-0"
>
  <!-- Pinned Content Panel (GSAP pins this on desktop) -->
  <div
    class="gallery-sticky-panel relative w-full h-auto md:h-screen flex flex-col justify-start md:justify-center items-center overflow-hidden"
  >
    <!-- Title overlay -->
    <div
      class="w-full max-w-7xl mx-auto px-6 md:px-12 mb-12 md:absolute md:top-16 md:left-12 md:px-0 md:mb-0 z-20 pointer-events-none"
    >
      <span class="text-brand-mint font-mono text-xs uppercase tracking-[2.5px] block mb-2"
        >CLAY & COAL CHRONICLES</span
      >
      <h2
        class="font-display text-4xl md:text-6xl uppercase leading-none font-black text-hazard-white tracking-tight"
      >
        THE SOUL OF THE HEARTH
      </h2>
    </div>

    <!-- Stacked Cards Wrapper -->
    <div
      class="relative w-full max-w-[340px] aspect-[4/5] mx-auto mt-20 md:mt-0 flex items-center justify-center md:relative md:max-w-none md:w-[460px] md:aspect-[4/5] md:h-auto md:flex md:items-center md:justify-center z-10 md:px-0"
    >
      {
        galleryItems.map((galleryItem) => {
          return (
            <div class="gallery-card absolute w-full aspect-[4/5] md:absolute md:w-full md:h-full md:aspect-none rounded-[24px] overflow-hidden border border-white/10 bg-surface-slate p-3 flex flex-col gap-4 shadow-none md:shadow-2xl origin-bottom">
              {/* Card Image */}
              <div class="relative flex-grow rounded-[16px] overflow-hidden border border-image-frame bg-canvas-black">
                <Image
                  src={galleryItem.image}
                  alt={galleryItem.alt}
                  class="gallery-img w-full h-full object-cover filter brightness-90 contrast-105 pointer-events-none"
                  loading="lazy"
                  decoding="async"
                  widths={[320, 460, 640, 920]}
                  sizes="(min-width: 768px) 460px, (min-width: 640px) 50vw, 100vw"
                  format="webp"
                  quality={78}
                />
                <div class="absolute top-4 left-4 bg-canvas-black border border-white/10 px-3 py-1 rounded-full">
                  <span class="text-[9px] font-mono uppercase tracking-[1.5px] text-brand-mint">
                    {galleryItem.tag}
                  </span>
                </div>
              </div>

              {/* Card Label */}
              <div class="flex justify-between items-center px-2 py-1 border-t border-white/5">
                <span class="font-sans text-sm font-bold text-hazard-white">
                  {galleryItem.title}
                </span>
                <span class="font-mono text-[10px] text-secondary-text">{galleryItem.id}</span>
              </div>
            </div>
          );
        })
      }
    </div>

    <!-- Background glowing text behind stack -->
    <div
      class="hidden md:block absolute bottom-16 right-12 z-20 pointer-events-none text-right font-mono text-[10px] text-secondary-text tracking-[2px] uppercase"
    >
      SCROLL DOWN TO FLIP PAGES <span class="text-brand-mint animate-pulse">▼</span>
    </div>
  </div>
</section>

<script>
  import { gsap } from 'gsap';

  let mediaMatcher = gsap.matchMedia();

  document.addEventListener('DOMContentLoaded', () => {
    mediaMatcher.revert();
    const pinContainer = document.querySelector('.gallery-pin-container') as HTMLElement;
    const galleryCards = gsap.utils.toArray('.gallery-card') as HTMLElement[];

    if (!pinContainer || galleryCards.length === 0) return;

    mediaMatcher.add(
      {
        isDesktop: '(min-width: 768px)',
        isMobile: '(max-width: 767px)',
      },
      (context) => {
        const { isDesktop } = context.conditions as { isDesktop: boolean };

        gsap.set('.gallery-sticky-panel', { willChange: 'transform', force3D: true });
        gsap.set(galleryCards, { willChange: 'transform, opacity', force3D: true });

        galleryCards.forEach((cardElement, cardIndex) => {
          const rotations = [-2, 3, -1.5, 2];
          const cardRotation = rotations[cardIndex % rotations.length];
          gsap.set(cardElement, {
            rotation: cardRotation,
            zIndex: 40 - cardIndex,
            xPercent: 0,
            yPercent: 0,
            scale: 1,
            opacity: 1,
          });
        });

        const stackTimeline = gsap.timeline({
          scrollTrigger: {
            trigger: '.gallery-pin-container',
            pin: '.gallery-sticky-panel',
            scrub: isDesktop ? 0.6 : 0.2,
            start: 'top top',
            end: 'bottom bottom',
          },
        });

        // We slide out the top cards one by one to reveal the lower ones
        stackTimeline.to(galleryCards[0], {
          xPercent: -130,
          rotation: -15,
          opacity: 0,
          ease: 'power2.inOut',
        });

        stackTimeline.fromTo(
          galleryCards[1],
          { scale: 0.94 },
          { scale: 1, duration: 0.5, ease: 'power2.out' },
          '-=0.4',
        );

        stackTimeline.to(galleryCards[1], {
          xPercent: 130,
          rotation: 15,
          opacity: 0,
          ease: 'power2.inOut',
        });

        stackTimeline.fromTo(
          galleryCards[2],
          { scale: 0.94 },
          { scale: 1, duration: 0.5, ease: 'power2.out' },
          '-=0.4',
        );

        stackTimeline.to(galleryCards[2], {
          yPercent: -130,
          rotation: -8,
          opacity: 0,
          ease: 'power2.inOut',
        });

        stackTimeline.fromTo(
          galleryCards[3],
          { scale: 0.94, rotation: 2 },
          {
            scale: 1.03,
            rotation: 0,
            duration: 0.6,
            ease: 'back.out(1.5)',
          },
          '-=0.4',
        );

        stackTimeline.to({}, { duration: 0.3 });
      },
    );
  });
</script>
