---
const galleryItems = [
  {
    id: "h-01",
    tag: "THE TANDOOR",
    title: "900°F Clay Oven",
    image: "/images/gallery_tandoor.png",
    alt: "Skewers of chicken roasting inside a glowing clay tandoor oven"
  },
  {
    id: "h-02",
    tag: "THE SIGREE",
    title: "Coal-Fired Kebabs",
    image: "/images/gallery_sigree.png",
    alt: "Spicy chicken kebabs cooking over an open-air charcoal sigree grill"
  },
  {
    id: "h-03",
    tag: "THE MASALA",
    title: "Stone-Ground Spices",
    image: "/images/gallery_spices.png",
    alt: "Aromatic whole Indian spices being crushed on a stone mortar"
  },
  {
    id: "h-04",
    tag: "THE DUM HANDI",
    title: "Slow-Steamed Biryani",
    image: "/images/gallery_biryani.png",
    alt: "Dough-sealed clay handi pot cooking biryani over dying embers"
  }
];
---

<section id="gallery" class="gallery-pin-container relative w-full h-auto md:h-[250vh] bg-canvas-black overflow-visible py-16 md:py-0">
  <!-- Pinned Content Panel (GSAP pins this on desktop) -->
  <div class="gallery-sticky-panel relative w-full h-auto md:h-screen flex flex-col justify-start md:justify-center items-center overflow-visible md:overflow-hidden">
    
    <!-- Title overlay -->
    <div class="w-full max-w-7xl mx-auto px-6 md:px-12 mb-12 md:absolute md:top-16 md:left-12 md:px-0 md:mb-0 z-20 pointer-events-none">
      <span class="text-brand-mint font-mono text-xs uppercase tracking-[2.5px] block mb-2">CLAY & COAL CHRONICLES</span>
      <h2 class="font-display text-4xl md:text-6xl uppercase leading-none font-black text-hazard-white tracking-tight">
        THE SOUL OF THE HEARTH
      </h2>
    </div>

    <!-- Stacked Cards Wrapper -->
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-8 w-full max-w-lg sm:max-w-3xl md:max-w-none md:relative md:w-[460px] md:h-[580px] md:flex md:items-center md:justify-center z-10 px-6 md:px-0">
      {galleryItems.map((item) => {
        return (
          <div 
            class="gallery-card relative w-full aspect-[4/5] sm:aspect-[3/4] md:absolute md:w-full md:h-full md:aspect-none rounded-[24px] overflow-hidden border border-white/10 bg-surface-slate p-3 flex flex-col gap-4 shadow-2xl origin-bottom"
          >
            <!-- Card Image -->
            <div class="relative flex-grow rounded-[16px] overflow-hidden border border-image-frame bg-canvas-black">
              <img 
                src={item.image} 
                alt={item.alt}
                class="gallery-img w-full h-full object-cover filter brightness-90 contrast-105 pointer-events-none"
                loading="lazy"
              />
              <div class="absolute top-4 left-4 bg-canvas-black/80 backdrop-blur-sm border border-white/10 px-3 py-1 rounded-full">
                <span class="text-[9px] font-mono uppercase tracking-[1.5px] text-brand-mint">{item.tag}</span>
              </div>
            </div>

            <!-- Card Label -->
            <div class="flex justify-between items-center px-2 py-1 border-t border-white/5">
              <span class="font-sans text-sm font-bold text-hazard-white">{item.title}</span>
              <span class="font-mono text-[10px] text-secondary-text">{item.id}</span>
            </div>
          </div>
        );
      })}
    </div>

    <!-- Background glowing text behind stack -->
    <div class="hidden md:block absolute bottom-16 right-12 z-20 pointer-events-none text-right font-mono text-[10px] text-secondary-text tracking-[2px] uppercase">
      SCROLL DOWN TO FLIP PAGES <span class="text-brand-mint animate-pulse">▼</span>
    </div>
  </div>
</section>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  document.addEventListener('DOMContentLoaded', () => {
    const pinContainer = document.querySelector('.gallery-pin-container') as HTMLElement;
    const galleryCards = gsap.utils.toArray('.gallery-card') as HTMLElement[];

    if (!pinContainer || galleryCards.length === 0) return;

    let mm = gsap.matchMedia();

    mm.add({
      isDesktop: "(min-width: 768px)",
      isMobile: "(max-width: 767px)"
    }, (context) => {
      const { isDesktop } = context.conditions as { isDesktop: boolean };

      if (isDesktop) {
        // Set initial stack z-indexes and rotations dynamically for desktop
        galleryCards.forEach((card, index) => {
          const rotations = [-2, 3, -1.5, 2];
          const rot = rotations[index % rotations.length];
          gsap.set(card, {
            rotation: rot,
            zIndex: 40 - index,
            xPercent: 0,
            yPercent: 0,
            scale: 1,
            opacity: 1
          });
        });

        // Create ScrollTrigger timeline pinning the sticky panel inside the container
        const tl = gsap.timeline({
          scrollTrigger: {
            trigger: pinContainer,
            pin: ".gallery-sticky-panel",
            scrub: 0.6,
            start: "top top",
            end: "bottom bottom",
            invalidateOnRefresh: true,
          }
        });

        // We slide out the top cards one by one to reveal the lower ones
        // Card 0 (top): slides left & rotates
        tl.to(galleryCards[0], {
          xPercent: -130,
          rotation: -15,
          opacity: 0,
          ease: "power2.inOut"
        });

        // As Card 0 leaves, Card 1 scales up slightly
        tl.fromTo(galleryCards[1],
          { scale: 0.94 },
          { scale: 1, duration: 0.5, ease: "power2.out" },
          "-=0.4"
        );

        // Card 1: slides right & rotates
        tl.to(galleryCards[1], {
          xPercent: 130,
          rotation: 15,
          opacity: 0,
          ease: "power2.inOut"
        });

        // Card 2 scales up
        tl.fromTo(galleryCards[2],
          { scale: 0.94 },
          { scale: 1, duration: 0.5, ease: "power2.out" },
          "-=0.4"
        );

        // Card 2: slides upwards
        tl.to(galleryCards[2], {
          yPercent: -130,
          rotation: -8,
          opacity: 0,
          ease: "power2.inOut"
        });

        // Card 3 (last) scales to 1.05 and rotates to 0
        tl.fromTo(galleryCards[3],
          { scale: 0.94, rotation: 2 },
          { scale: 1.03, rotation: 0, duration: 0.6, ease: "back.out(1.5)" },
          "-=0.4"
        );
        
        // Add a small pause at the end of the stack
        tl.to({}, { duration: 0.3 });

      } else {
        // Mobile Layout: clear all inline styles so they render in standard grid flow
        gsap.set(galleryCards, { clearProps: "all" });
        
        // Fade in reveals for individual cards in the grid as they scroll into view
        galleryCards.forEach((card) => {
          gsap.from(card, {
            opacity: 0,
            scale: 0.95,
            y: 30,
            duration: 0.6,
            scrollTrigger: {
              trigger: card,
              start: "top 85%",
              toggleActions: "play none none none"
            }
          });
        });
      }
    });
  });
</script>
