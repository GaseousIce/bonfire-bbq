---

<div
  id="loading-screen"
  class="fixed inset-0 z-[100] flex flex-col items-center justify-center bg-canvas-black select-none"
>
  <div class="flex flex-col items-center gap-6">
    <!-- Dual-ring spinner -->
    <div class="loading-spinner relative w-12 h-12 opacity-0">
      <div class="loading-ring-a absolute inset-0 rounded-full border-[1.5px] border-transparent border-t-brand-mint border-r-brand-mint"></div>
      <div class="loading-ring-b absolute inset-[4px] rounded-full border-[1.5px] border-transparent border-b-brand-purple border-l-brand-purple"></div>
    </div>

    <div
      class="loading-progress-wrap w-40 md:w-56 h-[2px] bg-white/10 mt-8 overflow-hidden rounded-full opacity-0"
    >
      <div class="loading-progress-bar h-full w-0 bg-brand-mint rounded-full"></div>
    </div>

    <p class="loading-pct font-mono text-[10px] tracking-[2px] text-hazard-white/40 opacity-0">
      0%
    </p>
  </div>
</div>

<script>
  import { gsap } from 'gsap';

  document.addEventListener('DOMContentLoaded', () => {
    const screen = document.getElementById('loading-screen');
    const progressWrap = document.querySelector('.loading-progress-wrap');
    const progressBar = document.querySelector('.loading-progress-bar') as HTMLElement | null;
    const percentDisplay = document.querySelector('.loading-pct') as HTMLElement | null;
    const spinner = document.querySelector('.loading-spinner');
    const ringA = document.querySelector('.loading-ring-a');
    const ringB = document.querySelector('.loading-ring-b');

    if (!screen || !progressBar || !percentDisplay || !spinner || !ringA || !ringB) return;

    const startTime = Date.now();
    const MIN_DURATION = 800;

    // Entrance timeline
    const revealTimeline = gsap.timeline({ defaults: { ease: 'power3.out' } });

    revealTimeline
      .to(spinner, { autoAlpha: 1, duration: 0.6 })
      .to(progressWrap, { autoAlpha: 1, duration: 0.5 }, '-=0.1')
      .to(percentDisplay, { autoAlpha: 1, duration: 0.3 }, '<');

    // Continuous rotation
    gsap.to(ringA, { rotation: 360, duration: 2.5, repeat: -1, ease: 'none' });
    gsap.to(ringB, { rotation: -360, duration: 3.5, repeat: -1, ease: 'none' });

    // Gentle pulse
    gsap.to(spinner, { scale: 1.08, duration: 2, yoyo: true, repeat: -1, ease: 'sine.inOut' });

    // Fake progress fill (stops at 80%, waiting for real load)
    const progress = { currentPercent: 0 };
    const fillTween = gsap.to(progress, {
      currentPercent: 80,
      duration: 2,
      ease: 'power1.inOut',
      delay: revealTimeline.duration(),
      onUpdate: () => {
        const percent = Math.round(progress.currentPercent);
        progressBar.style.width = percent + '%';
        percentDisplay.textContent = percent + '%';
      },
    });

    const completeLoading = () => {
      const elapsed = Date.now() - startTime;
      const remaining = Math.max(0, MIN_DURATION - elapsed);

      setTimeout(() => {
        fillTween.kill();
        gsap.to(progress, {
          currentPercent: 100,
          duration: 0.3,
          ease: 'power2.out',
          overwrite: true,
          onUpdate: () => {
            const percent = Math.round(progress.currentPercent);
            progressBar.style.width = percent + '%';
            percentDisplay.textContent = percent + '%';
          },
          onComplete: () => {
            // Run Hero cinematic entrance inline rather than through custom event
             const heroBackgroundWrapper = document.querySelector('.hero-bg-wrap') as HTMLElement | null;
             const eyebrow = document.querySelector('.hero-eyebrow');
             const chars = document.querySelectorAll('.hero-char');
             const deck = document.querySelector('.hero-deck');
             const heroCta = document.querySelector('.hero-cta');
             const scrollDown = document.querySelector('.hero-scroll-down');

             const bgScale = parseFloat(heroBackgroundWrapper?.dataset.parallaxScale || '1.12');
             const startScale = bgScale + 0.13;

             const masterTimeline = gsap.timeline({ defaults: { ease: 'power3.out' } });

             masterTimeline.fromTo(
               heroBackgroundWrapper,
               { scale: startScale },
               { scale: bgScale, duration: 2.2, ease: 'power2.out' }
             );

            masterTimeline.to(
              chars,
              {
                y: '0%',
                rotation: 0,
                stagger: 0.08,
                duration: 1.2,
                ease: 'back.out(1.5)',
              },
              '-=1.6',
            );

            masterTimeline.to(
              eyebrow,
              {
                y: 0,
                opacity: 1,
                duration: 0.8,
              },
              '-=0.8',
            );

            masterTimeline.to(
              deck,
              {
                y: 0,
                opacity: 1,
                duration: 0.8,
              },
              '-=0.6',
            );

            masterTimeline.to(
              heroCta,
              {
                y: 0,
                opacity: 1,
                duration: 0.9,
                ease: 'back.out(1.8)',
              },
              '-=0.4',
            );

            masterTimeline.to(
              scrollDown,
              {
                opacity: 1,
                duration: 0.6,
              },
              '-=0.2',
            );

            gsap.to(screen, {
              autoAlpha: 0,
              scale: 0.95,
              duration: 0.8,
              ease: 'power2.inOut',
              delay: 0.3,
              onComplete: () => screen.remove(),
            });
          },
        });
      }, remaining);
    };

    if (document.readyState === 'complete') {
      completeLoading();
    } else {
      window.addEventListener('load', completeLoading);
    }
  });
</script>
