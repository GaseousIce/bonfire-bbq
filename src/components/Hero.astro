---
import Button from './Button.astro';
import { Image } from 'astro:assets';
import { heroTandoor } from '../assets/images';
---

<section
  id="hero"
  class="relative w-full min-h-screen flex flex-col justify-center items-center overflow-hidden bg-canvas-black select-none"
>
  <!-- Background Image with Parallax wrapper -->
  <div class="absolute inset-0 w-full h-full scale-[1.12] hero-bg-wrap">
    <Image
      src={heroTandoor}
      alt="Bonfire Indian tandoor cooking"
      class="w-full h-full object-cover filter brightness-30 contrast-125 select-none pointer-events-none"
      loading="eager"
      fetchpriority="high"
      decoding="async"
      widths={[640, 960, 1280, 1600, 1920]}
      sizes="100vw"
      format="webp"
      quality={82}
    />
    <div
      class="absolute inset-0 bg-gradient-to-t from-canvas-black via-transparent to-canvas-black/80"
    >
    </div>
  </div>

  <!-- Drifting Smoke Layers -->
  <div class="absolute inset-0 pointer-events-none z-10 opacity-20 mix-blend-plus-lighter select-none">
    <div
      class="smoke-layer smoke-1 absolute -inset-[10%] bg-[url('https://images.unsplash.com/photo-1556388275-bb5585725aca?auto=format&fit=crop&w=1200&q=80')] bg-cover"
    >
    </div>
    <div
      class="smoke-layer smoke-2 absolute -inset-[10%] bg-[url('https://images.unsplash.com/photo-1602410086232-0cdfb78b434f?auto=format&fit=crop&w=1200&q=80')] bg-cover"
    >
    </div>
  </div>

  <!-- Content Container -->
  <div
    class="hero-content relative z-20 max-w-5xl mx-auto px-6 text-center flex flex-col items-center gap-6 pointer-events-auto"
  >
    <!-- Eyebrow Capitalized Label -->
    <span
      class="hero-eyebrow text-xs md:text-sm font-mono uppercase tracking-[3px] text-brand-mint translate-y-8 opacity-0"
    >
      Est. 2026 / Indian Coal & Clay Oven Craft
    </span>

    <!-- Headline: Staggered Characters -->
    <h1
      class="hero-title font-display uppercase leading-[0.85] text-hazard-white text-[min(18vw,160px)] font-black tracking-tighter select-none flex flex-wrap justify-center overflow-hidden py-2"
    >
      {
        Array.from('BONFIRE').map((char, index) => (
          <span
            class="hero-char inline-block translate-y-[110%] rotate-6 transform"
            style={`transform-origin: bottom center;`}
          >
            {char}
          </span>
        ))
      }
    </h1>

    <!-- Supporting deck -->
    <p
      class="hero-deck max-w-xl text-sm md:text-base font-serif italic text-hazard-white/70 translate-y-8 opacity-0 leading-relaxed"
    >
      A sensory feast carved by Indian spices, tandoor clay ovens, and open-flame cooking. Where
      ancient spice routes meet modern charcoal craft.
    </p>

    <!-- CTAs -->
    <div
      class="hero-cta flex flex-wrap gap-12 justify-center items-center mt-6 translate-y-8 opacity-0"
    >
      <Button href="#reserve" variant="primary" class="hero-cta-btn text-[11px] tracking-[1.5px] px-8 py-3.5">
        Reserve A Hearth
      </Button>
      <Button href="#dishes" variant="outline" class="hero-cta-btn text-[11px] tracking-[1.5px] px-8 py-3.5">
        Explore Menu
      </Button>
    </div>
  </div>

  <!-- Scroll Down Indicator -->
  <div
    class="absolute bottom-10 left-1/2 -translate-x-1/2 z-20 flex flex-col items-center gap-2 pointer-events-none opacity-0 hero-scroll-down"
  >
    <span class="text-[9px] font-mono uppercase tracking-[2px] text-hazard-white/40"
      >Scroll to ignite</span
    >
    <div class="w-[1px] h-12 bg-white/20 relative overflow-hidden">
      <div class="absolute top-0 left-0 w-full h-1/2 bg-brand-mint"></div>
    </div>
  </div>
</section>

<style>
  .smoke-layer {
    background-position: center;
    will-change: transform, opacity;
  }
</style>

<script>
  import { gsap } from 'gsap';

  document.addEventListener('DOMContentLoaded', () => {
    const bgWrap = document.querySelector('.hero-bg-wrap');
    const eyebrow = document.querySelector('.hero-eyebrow');
    const chars = document.querySelectorAll('.hero-char');
    const deck = document.querySelector('.hero-deck');
    const cta = document.querySelector('.hero-cta');
    const scrollDown = document.querySelector('.hero-scroll-down');

    // ----------------------------------------------------
    // 1. Cinematic Opening sequence (deferred until loading screen completes)
    // ----------------------------------------------------
    const startCinematic = () => {
      const masterTl = gsap.timeline({ defaults: { ease: 'power3.out' } });

      // Background settles: zoom/scale reduction from 1.15 to 1
      masterTl.fromTo(bgWrap, { scale: 1.15 }, { scale: 1, duration: 2.2, ease: 'power2.out' });

      // Characters stagger upwards with slight rotation overshoot
      masterTl.to(
        chars,
        {
          y: '0%',
          rotation: 0,
          stagger: 0.08,
          duration: 1.2,
          ease: 'back.out(1.5)',
        },
        '-=1.6',
      );

      // Eyebrow and supporting content follow
      masterTl.to(
        eyebrow,
        {
          y: 0,
          opacity: 1,
          duration: 0.8,
        },
        '-=0.8',
      );

      masterTl.to(
        deck,
        {
          y: 0,
          opacity: 1,
          duration: 0.8,
        },
        '-=0.6',
      );

      // CTA enters with spring overshoot
      masterTl.to(
        cta,
        {
          y: 0,
          opacity: 1,
          duration: 0.9,
          ease: 'back.out(1.8)',
        },
        '-=0.4',
      );

      // Scroll Down Indicator enters
      masterTl.to(
        scrollDown,
        {
          opacity: 1,
          duration: 0.6,
        },
        '-=0.2',
      );
    };

    document.addEventListener('loading-complete', startCinematic, { once: true });

    // ----------------------------------------------------
    // 2. Mouse Parallax (Gentle Depth Movement)
    // ----------------------------------------------------
    const heroSection = document.getElementById('hero');
    let mouseX = 0;
    let mouseY = 0;
    let animationFrameId: number | null = null;

    const updateParallax = () => {
      if (!heroSection) return;
      const { width, height } = heroSection.getBoundingClientRect();
      const xDiff = mouseX - width / 2;
      const yDiff = mouseY - height / 2;

      // Parallax values
      gsap.to(bgWrap, {
        x: -xDiff * 0.025,
        y: -yDiff * 0.025,
        duration: 1.2,
        ease: 'power2.out',
      });

      gsap.to('.hero-content', {
        x: xDiff * 0.015,
        y: yDiff * 0.015,
        duration: 1.0,
        ease: 'power2.out',
      });

      gsap.to('.smoke-1', {
        x: xDiff * 0.04,
        y: yDiff * 0.04,
        duration: 1.5,
        ease: 'power1.out',
      });

      gsap.to('.smoke-2', {
        x: -xDiff * 0.03,
        y: -yDiff * 0.03,
        duration: 1.8,
        ease: 'power1.out',
      });

      animationFrameId = null;
    };

    heroSection?.addEventListener('mousemove', (e) => {
      mouseX = e.clientX;
      mouseY = e.clientY;

      if (animationFrameId === null) {
        animationFrameId = requestAnimationFrame(updateParallax);
      }
    });

    heroSection?.addEventListener('mouseleave', () => {
      if (animationFrameId !== null) {
        cancelAnimationFrame(animationFrameId);
        animationFrameId = null;
      }

      gsap.to([bgWrap, '.hero-content', '.smoke-1', '.smoke-2'], {
        x: 0,
        y: 0,
        scale: 1,
        duration: 1.5,
        ease: 'power2.out',
      });
    });

    // 3. Slow smoke drift animation
    gsap.to('.smoke-1', {
      xPercent: 12,
      yPercent: -8,
      duration: 25,
      repeat: -1,
      yoyo: true,
      ease: 'sine.inOut',
    });

    gsap.to('.smoke-2', {
      xPercent: -8,
      yPercent: 12,
      duration: 30,
      repeat: -1,
      yoyo: true,
      ease: 'sine.inOut',
    });

    // 4. Smooth scrolling for Hero CTA buttons
    const heroCtaBtns = document.querySelectorAll('.hero-cta-btn');
    const smoother = window.__smoother;

    const scrollToSection = (href: string) => {
      if (!smoother) return;
      if (href === '#hero') return smoother.scrollTo(0, false);
      const section = document.querySelector(href);
      if (!section) return;
      const rect = section.getBoundingClientRect();
      smoother.scrollTo(smoother.scrollTop() + rect.top - 80, false);
    };

    heroCtaBtns.forEach((btn) => {
      btn.addEventListener('click', (e) => {
        e.preventDefault();
        const href = btn.getAttribute('href');
        if (href) scrollToSection(href);
      });
    });
  });
</script>
