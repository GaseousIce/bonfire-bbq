---
import Button from './Button.astro';
import { Image } from 'astro:assets';
import { heroTandoor } from '../assets/images';
---

<section
  id="hero"
  class="relative w-full min-h-screen flex flex-col justify-center items-center overflow-hidden bg-canvas-black select-none"
>
  <!-- Background Image with Parallax wrapper -->
  <div class="absolute inset-0 w-full h-full scale-[1.12] hero-bg-wrap" data-parallax-scale="1.12">
    <Image
      src={heroTandoor}
      alt="Bonfire Indian tandoor cooking"
      class="w-full h-full object-cover filter brightness-30 contrast-125 select-none pointer-events-none"
      loading="eager"
      fetchpriority="high"
      decoding="async"
      widths={[640, 960, 1280, 1600, 1920]}
      sizes="100vw"
      format="webp"
      quality={82}
    />
    <div
      class="absolute inset-0 bg-gradient-to-t from-canvas-black via-transparent to-canvas-black/80"
    >
    </div>
  </div>

  <!-- Glowing tandoor hearth backdrop (expanding fire glow) -->
  <div
    class="absolute w-[300px] h-[300px] sm:w-[400px] sm:h-[400px] lg:w-[600px] lg:h-[600px] rounded-full bg-brand-purple/10 filter blur-[80px] sm:blur-[100px] lg:blur-[130px] pointer-events-none z-10 hero-glow"
  >
  </div>
  <div
    class="absolute w-[200px] h-[200px] sm:w-[300px] sm:h-[300px] lg:w-[400px] lg:h-[400px] rounded-full bg-brand-mint/3 filter blur-[50px] sm:blur-[70px] lg:blur-[90px] pointer-events-none z-10 hero-glow-secondary"
  >
  </div>

  <!-- Drifting Smoke Layers (Vignette Boundary Mask) -->
  <div
    class="absolute inset-0 pointer-events-none z-10 opacity-30 md:opacity-20 mix-blend-plus-lighter select-none smoke-container"
    style="mask-image: radial-gradient(circle, black 30%, transparent 80%); -webkit-mask-image: radial-gradient(circle, black 30%, transparent 80%);"
  >
    <div class="smoke-parallax-1 absolute inset-0">
      <div
        class="smoke-layer smoke-1 absolute -inset-[20%] bg-[url('https://images.unsplash.com/photo-1556388275-bb5585725aca?auto=format&fit=crop&w=1200&q=80')] bg-cover"
      >
      </div>
    </div>
    <div class="smoke-parallax-2 absolute inset-0">
      <div
        class="smoke-layer smoke-2 absolute -inset-[20%] bg-[url('https://images.unsplash.com/photo-1602410086232-0cdfb78b434f?auto=format&fit=crop&w=1200&q=80')] bg-cover"
      >
      </div>
    </div>
  </div>

  <!-- Content Container -->
  <div
    class="hero-content relative z-20 max-w-5xl mx-auto px-6 text-center flex flex-col items-center gap-6 pointer-events-auto"
  >
    <!-- Eyebrow Capitalized Label -->
    <span
      class="hero-eyebrow text-xs md:text-sm font-mono uppercase tracking-[3px] text-brand-mint translate-y-8 opacity-0"
    >
      Est. 2026 / Indian Coal & Clay Oven Craft
    </span>

    <!-- Headline: Staggered Characters -->
    <h1
      class="hero-title font-display uppercase leading-[0.85] text-hazard-white text-[clamp(48px,18vw,160px)] font-black tracking-wide select-none flex flex-wrap justify-center overflow-hidden py-2"
    >
      {
        Array.from('BONFIRE').map((char, index) => (
          <span
            class="hero-char inline-block translate-y-[110%] rotate-6 transform"
            style={`transform-origin: bottom center;`}
          >
            {char}
          </span>
        ))
      }
    </h1>

    <!-- Supporting deck -->
    <p
      class="hero-deck max-w-xl text-sm md:text-base font-serif italic text-hazard-white/70 translate-y-8 opacity-0 leading-relaxed"
    >
      A sensory feast carved by Indian spices, tandoor clay ovens, and open-flame cooking. Where
      ancient spice routes meet modern charcoal craft.
    </p>

    <!-- CTAs -->
    <div
      class="hero-cta flex flex-wrap gap-6 md:gap-12 justify-center items-center mt-6 translate-y-8 opacity-0"
    >
      <Button
        href="#reserve"
        variant="primary"
        class="hero-cta-btn text-[11px] tracking-[1.5px] px-8 py-3.5"
      >
        Reserve A Hearth
      </Button>
      <Button
        href="#dishes"
        variant="outline"
        class="hero-cta-btn text-[11px] tracking-[1.5px] px-8 py-3.5"
      >
        Explore Menu
      </Button>
    </div>
  </div>

  <!-- Scroll Down Indicator -->
  <div
    class="absolute bottom-10 left-1/2 -translate-x-1/2 z-20 flex flex-col items-center gap-2 pointer-events-none opacity-0 hero-scroll-down"
  >
    <span class="text-[9px] font-mono uppercase tracking-[2px] text-hazard-white/40"
      >Scroll to ignite</span
    >
    <div class="w-[1px] h-12 bg-white/20 relative overflow-hidden">
      <div class="absolute top-0 left-0 w-full h-1/2 bg-brand-mint"></div>
    </div>
  </div>
</section>

<style>
  .smoke-layer,
  .hero-glow,
  .hero-glow-secondary {
    will-change: transform, opacity;
  }
  .smoke-layer {
    background-position: center;
  }
</style>

<script>
  import { gsap } from 'gsap';
  import { handleNavClick } from '../utils/navigateWithTransition';

  document.addEventListener('DOMContentLoaded', () => {
    const heroBackgroundWrapper = document.querySelector('.hero-bg-wrap') as HTMLElement | null;
    const heroContent = document.querySelector('.hero-content') as HTMLElement | null;
    const smoke1 = document.querySelector('.smoke-1') as HTMLElement | null;
    const smoke2 = document.querySelector('.smoke-2') as HTMLElement | null;
    const smokeParallax1 = document.querySelector('.smoke-parallax-1') as HTMLElement | null;
    const smokeParallax2 = document.querySelector('.smoke-parallax-2') as HTMLElement | null;
    const heroGlow = document.querySelector('.hero-glow') as HTMLElement | null;
    const heroGlowSecondary = document.querySelector('.hero-glow-secondary') as HTMLElement | null;

    if (!heroBackgroundWrapper || !heroContent || !smoke1 || !smoke2) return;

    // Read target scale dynamically from HTML attribute (single source of truth)
    const bgScale = parseFloat(heroBackgroundWrapper.dataset.parallaxScale || '1.12') || 1.12;

    // Enforce default scale on background wrapper to initialize GSAP transform cache
    gsap.set(heroBackgroundWrapper, { scale: bgScale });

    // ----------------------------------------------------
    // 2. Mouse Parallax — only on hover-capable devices
    // ----------------------------------------------------
    const heroMm = gsap.matchMedia();
    heroMm.add('(hover: hover)', () => {
      const heroSection = document.getElementById('hero');
      if (!heroSection) return;

      let heroWidth = heroSection.offsetWidth;
      let heroHeight = heroSection.offsetHeight;

      window.addEventListener('resize', () => {
        heroWidth = heroSection.offsetWidth;
        heroHeight = heroSection.offsetHeight;
      });

      let mouseX = 0;
      let mouseY = 0;
      let animationFrameId: number | null = null;

      const updateParallax = () => {
        const xOffset = mouseX - heroWidth / 2;
        const yOffset = mouseY - heroHeight / 2;

        gsap.to(heroBackgroundWrapper, {
          x: -xOffset * 0.025,
          y: -yOffset * 0.025,
          scale: bgScale,
          duration: 1.2,
          ease: 'power2.out',
          overwrite: 'auto',
        });

        gsap.to(heroContent, {
          x: xOffset * 0.015,
          y: yOffset * 0.015,
          duration: 1.0,
          ease: 'power2.out',
          overwrite: 'auto',
        });

        gsap.to(smoke1, {
          x: xOffset * 0.04,
          y: yOffset * 0.04,
          duration: 1.5,
          ease: 'power1.out',
          overwrite: 'auto',
        });

        gsap.to(smoke2, {
          x: -xOffset * 0.03,
          y: -yOffset * 0.03,
          duration: 1.8,
          ease: 'power1.out',
          overwrite: 'auto',
        });

        gsap.to([heroGlow, heroGlowSecondary], {
          x: xOffset * 0.01,
          y: yOffset * 0.01,
          duration: 1.3,
          overwrite: 'auto',
        });

        animationFrameId = null;
      };

      heroSection.addEventListener('mousemove', (mouseEvent: MouseEvent) => {
        mouseX = mouseEvent.clientX;
        mouseY = mouseEvent.clientY;

        if (animationFrameId === null) {
          animationFrameId = requestAnimationFrame(updateParallax);
        }
      });

      heroSection.addEventListener('mouseleave', () => {
        if (animationFrameId !== null) {
          cancelAnimationFrame(animationFrameId);
          animationFrameId = null;
        }

        gsap.to(heroBackgroundWrapper, {
          x: 0,
          y: 0,
          scale: bgScale,
          duration: 1.5,
          ease: 'power2.out',
          overwrite: 'auto',
        });

        gsap.to([heroContent, smoke1, smoke2], {
          x: 0,
          y: 0,
          scale: 1,
          duration: 1.5,
          ease: 'power2.out',
          overwrite: 'auto',
        });

        gsap.to([heroGlow, heroGlowSecondary], {
          x: 0,
          y: 0,
          duration: 1.5,
          ease: 'power2.out',
          overwrite: 'auto',
        });
      });
    });

    // ----------------------------------------------------
    // 3. Continuous Smoke & Glow Animations — runs on all devices
    // ----------------------------------------------------
    // Smoke drift animation — continuous organic movement
    const smokeTl = gsap.timeline({ repeat: -1 });
    smokeTl
      .to(smoke1, { xPercent: 18, yPercent: -12, duration: 14, ease: 'sine.inOut' })
      .to(smoke1, { xPercent: -6, yPercent: 4, duration: 18, ease: 'sine.inOut' })
      .to(smoke1, { xPercent: 0, yPercent: 0, duration: 16, ease: 'sine.inOut' });

    const smokeTl2 = gsap.timeline({ repeat: -1 });
    smokeTl2
      .to(smoke2, { xPercent: -14, yPercent: 10, duration: 16, ease: 'sine.inOut' })
      .to(smoke2, { xPercent: 8, yPercent: -6, duration: 14, ease: 'sine.inOut' })
      .to(smoke2, { xPercent: 0, yPercent: 0, duration: 20, ease: 'sine.inOut' });

    // Subtle scale breathing for volumetric feel
    gsap.to(smoke1, { scale: 1.08, duration: 12, repeat: -1, yoyo: true, ease: 'sine.inOut' });
    gsap.to(smoke2, { scale: 1.06, duration: 15, repeat: -1, yoyo: true, ease: 'sine.inOut' });

    // Background glow pulsing animations
    gsap.fromTo(
      heroGlow,
      { scale: 0.9, opacity: 0.3 },
      {
        scale: 1.15,
        opacity: 0.65,
        duration: 5,
        repeat: -1,
        yoyo: true,
        ease: 'sine.inOut',
      },
    );

    gsap.fromTo(
      heroGlowSecondary,
      { scale: 1.1, opacity: 0.1 },
      {
        scale: 0.85,
        opacity: 0.35,
        duration: 3.8,
        repeat: -1,
        yoyo: true,
        ease: 'sine.inOut',
      },
    );

    // ----------------------------------------------------
    // 4. Scroll-based Parallax — runs on all devices
    // ----------------------------------------------------
    gsap.to(heroBackgroundWrapper, {
      yPercent: 10,
      ease: 'none',
      scrollTrigger: {
        trigger: '#hero',
        start: 'top top',
        end: 'bottom top',
        scrub: 0.5,
      },
    });

    if (smokeParallax1) {
      gsap.to(smokeParallax1, {
        yPercent: -15,
        ease: 'none',
        scrollTrigger: {
          trigger: '#hero',
          start: 'top top',
          end: 'bottom top',
          scrub: 0.5,
        },
      });
    }

    if (smokeParallax2) {
      gsap.to(smokeParallax2, {
        yPercent: -12,
        ease: 'none',
        scrollTrigger: {
          trigger: '#hero',
          start: 'top top',
          end: 'bottom top',
          scrub: 0.5,
        },
      });
    }

    // Hero CTA buttons via page transition
    const heroCtaButtons = document.querySelectorAll('.hero-cta-btn');
    heroCtaButtons.forEach((btn) => btn.addEventListener('click', handleNavClick));

    // Hero entrance timeline (triggered by LoadingScreen)
    document.addEventListener('bonfire:hero-entrance', () => {
      const hbw = document.querySelector('.hero-bg-wrap') as HTMLElement | null;
      const eyebrow = document.querySelector('.hero-eyebrow');
      const chars = document.querySelectorAll('.hero-char');
      const deck = document.querySelector('.hero-deck');
      const cta = document.querySelector('.hero-cta');
      const scrollDown = document.querySelector('.hero-scroll-down');

      if (!hbw) return;

      const bgScale = parseFloat(hbw.dataset.parallaxScale || '1.12') || 1.12;
      const startScale = bgScale + 0.13;

      const mt = gsap.timeline({ defaults: { ease: 'power3.out' } });

      mt.fromTo(hbw, { scale: startScale }, { scale: bgScale, duration: 2.2, ease: 'power2.out' });
      mt.to(
        chars,
        { y: '0%', rotation: 0, stagger: 0.08, duration: 1.2, ease: 'back.out(1.5)' },
        '-=1.6',
      );
      mt.to(eyebrow, { y: 0, opacity: 1, duration: 0.8 }, '-=0.8');
      mt.to(deck, { y: 0, opacity: 1, duration: 0.8 }, '-=0.6');
      mt.to(cta, { y: 0, opacity: 1, duration: 0.9, ease: 'back.out(1.8)' }, '-=0.4');
      mt.to(scrollDown, { opacity: 1, duration: 0.6 }, '-=0.2');
    });
  });
</script>
