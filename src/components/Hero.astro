---
---
<section id="hero" class="relative w-full min-h-screen flex flex-col justify-center items-center overflow-hidden bg-canvas-black select-none">
  <!-- Background Image with Parallax wrapper -->
  <div class="absolute inset-0 w-full h-full scale-[1.12] hero-bg-wrap">
    <img 
      src="https://images.unsplash.com/photo-1544025162-d76694265947?auto=format&fit=crop&w=1920&q=80" 
      alt="Bonfire woodfire cooking"
      class="w-full h-full object-cover filter brightness-30 contrast-125 select-none pointer-events-none"
      loading="eager"
    />
    <div class="absolute inset-0 bg-gradient-to-t from-canvas-black via-transparent to-canvas-black/80"></div>
  </div>

  <!-- Drifting Smoke Layers -->
  <div class="absolute inset-0 pointer-events-none z-10 opacity-30 select-none">
    <div class="smoke-layer smoke-1 absolute -inset-[10%] bg-[url('https://images.unsplash.com/photo-1608897013039-887f21d8c804?auto=format&fit=crop&w=1000&q=80')] bg-cover mix-blend-screen opacity-20 filter blur-lg"></div>
    <div class="smoke-layer smoke-2 absolute -inset-[10%] bg-[url('https://images.unsplash.com/photo-1546964124-0cce460f38ef?auto=format&fit=crop&w=1000&q=80')] bg-cover mix-blend-screen opacity-15 filter blur-2xl"></div>
  </div>

  <!-- Ember Particle Canvas -->
  <canvas id="ember-canvas" class="absolute inset-0 w-full h-full pointer-events-none z-15"></canvas>

  <!-- Content Container -->
  <div class="hero-content relative z-20 max-w-5xl mx-auto px-6 text-center flex flex-col items-center gap-6 pointer-events-auto">
    <!-- Eyebrow Capitalized Label -->
    <span class="hero-eyebrow text-xs md:text-sm font-mono uppercase tracking-[3px] text-brand-mint translate-y-8 opacity-0">
      Est. 2026 / Slow & Low Woodfire Craft
    </span>

    <!-- Headline: Staggered Characters -->
    <h1 class="hero-title font-display uppercase leading-[0.85] text-hazard-white text-[min(18vw,160px)] font-black tracking-tighter select-none flex flex-wrap justify-center overflow-hidden py-2">
      {
        Array.from("BONFIRE").map((char, index) => (
          <span class="hero-char inline-block translate-y-[110%] rotate-6 transform" style={`transform-origin: bottom center;`}>
            {char}
          </span>
        ))
      }
    </h1>

    <!-- Supporting deck -->
    <p class="hero-deck max-w-xl text-sm md:text-base font-serif italic text-hazard-white/70 translate-y-8 opacity-0 leading-relaxed">
      A sensory feast carved by smoke, flame, and time. Where every ember tells a story of patience, and every dish is a testament to primal fire.
    </p>

    <!-- CTAs -->
    <div class="hero-cta flex flex-wrap gap-4 justify-center items-center mt-6 translate-y-8 opacity-0">
      <a href="#reserve" class="magnetic-button bg-brand-mint text-canvas-black font-mono text-[11px] font-bold uppercase tracking-[1.5px] px-8 py-3.5 rounded-full border border-transparent hover:bg-white hover:text-canvas-black transition-all duration-300">
        <span class="magnetic-target block">Reserve A Hearth</span>
      </a>
      <a href="#dishes" class="magnetic-button bg-transparent text-hazard-white font-mono text-[11px] font-bold uppercase tracking-[1.5px] px-8 py-3.5 rounded-full border border-white/20 hover:border-brand-mint hover:text-brand-mint transition-all duration-300">
        <span class="magnetic-target block">Explore Menu</span>
      </a>
    </div>
  </div>

  <!-- Scroll Down Indicator -->
  <div class="absolute bottom-10 left-1/2 -translate-x-1/2 z-20 flex flex-col items-center gap-2 pointer-events-none opacity-0 hero-scroll-down">
    <span class="text-[9px] font-mono uppercase tracking-[2px] text-hazard-white/40">Scroll to ignite</span>
    <div class="w-[1px] h-12 bg-white/20 relative overflow-hidden">
      <div class="absolute top-0 left-0 w-full h-1/2 bg-brand-mint animate-bounce"></div>
    </div>
  </div>
</section>

<style>
  .smoke-layer {
    background-position: center;
  }
</style>

<script>
  import { gsap } from 'gsap';

  document.addEventListener('DOMContentLoaded', () => {
    const bgWrap = document.querySelector('.hero-bg-wrap');
    const eyebrow = document.querySelector('.hero-eyebrow');
    const chars = document.querySelectorAll('.hero-char');
    const deck = document.querySelector('.hero-deck');
    const cta = document.querySelector('.hero-cta');
    const scrollDown = document.querySelector('.hero-scroll-down');
    const canvas = document.getElementById('ember-canvas') as HTMLCanvasElement;
    
    // ----------------------------------------------------
    // 1. Cinematic Opening sequence
    // ----------------------------------------------------
    const masterTl = gsap.timeline({ defaults: { ease: 'power3.out' } });

    // Background settles: zoom/scale reduction from 1.15 to 1
    masterTl.fromTo(bgWrap, 
      { scale: 1.15 }, 
      { scale: 1, duration: 2.2, ease: 'power2.out' }
    );

    // Characters stagger upwards with slight rotation overshoot
    masterTl.to(chars, {
      y: '0%',
      rotation: 0,
      stagger: 0.08,
      duration: 1.2,
      ease: 'back.out(1.5)',
    }, '-=1.6');

    // Eyebrow and supporting content follow
    masterTl.to(eyebrow, {
      y: 0,
      opacity: 1,
      duration: 0.8
    }, '-=0.8');

    masterTl.to(deck, {
      y: 0,
      opacity: 1,
      duration: 0.8
    }, '-=0.6');

    // CTA enters with spring overshoot
    masterTl.to(cta, {
      y: 0,
      opacity: 1,
      duration: 0.9,
      ease: 'back.out(1.8)'
    }, '-=0.4');

    // Scroll Down Indicator enters
    masterTl.to(scrollDown, {
      opacity: 1,
      duration: 0.6
    }, '-=0.2');


    // ----------------------------------------------------
    // 2. Mouse Parallax (Gentle Depth Movement)
    // ----------------------------------------------------
    const heroSection = document.getElementById('hero');
    heroSection?.addEventListener('mousemove', (e) => {
      const { width, height } = heroSection.getBoundingClientRect();
      const xDiff = e.clientX - width / 2;
      const yDiff = e.clientY - height / 2;

      // Parallax values
      gsap.to(bgWrap, {
        x: -xDiff * 0.025,
        y: -yDiff * 0.025,
        duration: 1.2,
        ease: 'power2.out'
      });

      gsap.to('.hero-content', {
        x: xDiff * 0.015,
        y: yDiff * 0.015,
        duration: 1.0,
        ease: 'power2.out'
      });

      gsap.to('.smoke-1', {
        x: xDiff * 0.04,
        y: yDiff * 0.04,
        duration: 1.5,
        ease: 'power1.out'
      });

      gsap.to('.smoke-2', {
        x: -xDiff * 0.03,
        y: -yDiff * 0.03,
        duration: 1.8,
        ease: 'power1.out'
      });
    });

    heroSection?.addEventListener('mouseleave', () => {
      gsap.to([bgWrap, '.hero-content', '.smoke-1', '.smoke-2'], {
        x: 0,
        y: 0,
        scale: 1,
        duration: 1.5,
        ease: 'power2.out'
      });
    });


    // ----------------------------------------------------
    // 3. Floating Ember Particle Canvas
    // ----------------------------------------------------
    if (canvas) {
      const ctx = canvas.getContext('2d');
      let particles: Array<{
        x: number;
        y: number;
        size: number;
        speedX: number;
        speedY: number;
        alpha: number;
        decay: number;
        color: string;
      }> = [];

      const colors = [
        'rgba(60, 255, 208, ', // Mint spark
        'rgba(255, 124, 60, ', // Fire orange
        'rgba(255, 218, 68, ', // Yellow spark
        'rgba(255, 90, 95, ',  // Soft red ember
      ];

      const resizeCanvas = () => {
        canvas.width = window.innerWidth;
        canvas.height = window.innerHeight;
      };
      
      resizeCanvas();
      window.addEventListener('resize', resizeCanvas);

      const createParticle = () => {
        const x = Math.random() * canvas.width;
        const y = canvas.height + 20;
        const size = Math.random() * 2.5 + 0.5;
        const speedX = Math.random() * 2 - 1;
        const speedY = -(Math.random() * 1.5 + 0.5);
        const alpha = Math.random() * 0.8 + 0.2;
        const decay = Math.random() * 0.005 + 0.002;
        // Mint particles are rare (10% chance)
        const isMint = Math.random() < 0.15;
        const color = isMint ? colors[0] : colors[Math.floor(Math.random() * (colors.length - 1)) + 1];

        particles.push({ x, y, size, speedX, speedY, alpha, decay, color });
      };

      const animateParticles = () => {
        if (!ctx) return;
        ctx.clearRect(0, 0, canvas.width, canvas.height);

        // Generate particles based on screen width (less on mobile)
        const density = window.innerWidth < 768 ? 0.3 : 0.8;
        if (Math.random() < density) {
          createParticle();
        }

        particles.forEach((p, index) => {
          p.y += p.speedY;
          // Sine wave path drift
          p.x += p.speedX + Math.sin(p.y * 0.01) * 0.4;
          p.alpha -= p.decay;

          if (p.alpha <= 0 || p.y < -10) {
            particles.splice(index, 1);
            return;
          }

          ctx.beginPath();
          ctx.arc(p.x, p.y, p.size, 0, Math.PI * 2);
          ctx.fillStyle = `${p.color}${p.alpha})`;
          ctx.fill();
        });

        requestAnimationFrame(animateParticles);
      };

      animateParticles();
    }

    // 4. Slow smoke drift animation
    gsap.to('.smoke-1', {
      xPercent: 12,
      yPercent: -8,
      duration: 25,
      repeat: -1,
      yoyo: true,
      ease: 'sine.inOut'
    });
    
    gsap.to('.smoke-2', {
      xPercent: -8,
      yPercent: 12,
      duration: 30,
      repeat: -1,
      yoyo: true,
      ease: 'sine.inOut'
    });
  });
</script>
