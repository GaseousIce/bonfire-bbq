---
import Button from './Button.astro';
import ReservationInfo from './reservation/ReservationInfo.astro';
import CalendarPicker from './reservation/CalendarPicker.astro';
import TimePicker from './reservation/TimePicker.astro';
import CustomDropdown from './reservation/CustomDropdown.astro';
import BookingToast from './reservation/BookingToast.astro';
---

<section
  id="reserve"
  class="reserve-section relative w-full min-h-screen bg-canvas-black py-16 sm:py-20 lg:py-24 flex items-center justify-center z-20 border-t border-white/5"
>
  <!-- Glowing hearth backdrop -->
  <div
    class="absolute w-[300px] h-[300px] sm:w-[400px] sm:h-[400px] lg:w-[500px] lg:h-[500px] rounded-full bg-brand-purple/20 filter blur-[80px] sm:blur-[100px] lg:blur-[120px] pointer-events-none z-0 hearth-glow"
  >
  </div>
  <div
    class="absolute w-[200px] h-[200px] sm:w-[250px] sm:h-[250px] lg:w-[300px] lg:h-[300px] rounded-full bg-brand-mint/10 filter blur-[50px] sm:blur-[60px] lg:blur-[80px] pointer-events-none z-0 hearth-glow-secondary"
  >
  </div>

  <div class="max-w-6xl mx-auto w-full px-6 md:px-12 relative z-10">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-16 items-center">
      <!-- Left Column -->
      <ReservationInfo />

      <!-- Right Column: Booking Card Form -->
      <div class="lg:col-span-6 reserve-card-wrap">
        <div
          class="bg-surface-slate border border-white/10 rounded-[24px] p-6 md:p-8 flex flex-col gap-6 relative shadow-2xl hover:border-brand-mint/30 transition-[border-color] duration-300"
        >
          <div class="flex justify-between items-baseline border-b border-white/5 pb-4">
            <span
              class="font-mono text-[10px] uppercase tracking-[2px] text-brand-mint font-semibold"
              >HEARTH BOOKING</span
            >
            <span class="font-mono text-[9px] text-secondary-text">CODE: PIT-001</span>
          </div>

          <form class="flex flex-col gap-5" onsubmit="return false">
            <!-- Name & Email -->
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
              <div class="flex flex-col gap-2">
                <label
                  for="name"
                  class="font-mono text-[10px] uppercase tracking-[1.5px] text-hazard-white/80"
                  >Your Name</label
                >
                <!-- 🛡️ Sentinel: Added maxlength for defense in depth against DoS via massive payloads -->
                <input
                  type="text"
                  id="name"
                  name="name"
                  placeholder="e.g. Marcus Aurelius"
                  required
                  maxlength="100"
                  autocomplete="name"
                  class="bg-canvas-black border border-white/20 text-sm font-sans text-hazard-white placeholder-secondary-text px-4 py-3 rounded-[12px] focus:outline-none focus:border-brand-mint focus:ring-1 focus:ring-brand-purple transition-[border-color,box-shadow] duration-150"
                />
              </div>
              <div class="flex flex-col gap-2">
                <label
                  for="email"
                  class="font-mono text-[10px] uppercase tracking-[1.5px] text-hazard-white/80"
                  >Email Address</label
                >
                <!-- 🛡️ Sentinel: Added maxlength for defense in depth against DoS via massive payloads -->
                <input
                  type="email"
                  id="email"
                  name="email"
                  placeholder="e.g. pit@bonfire.com"
                  required
                  maxlength="150"
                  autocomplete="email"
                  class="bg-canvas-black border border-white/20 text-sm font-sans text-hazard-white placeholder-secondary-text px-4 py-3 rounded-[12px] focus:outline-none focus:border-brand-mint focus:ring-1 focus:ring-brand-purple transition-[border-color,box-shadow] duration-150"
                />
              </div>
            </div>

            <!-- Date & Time -->
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
              <CalendarPicker />
              <TimePicker />
            </div>

            <!-- Guests & Preference -->
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
              <CustomDropdown
                name="guests"
                label="Hearth Seating"
                placeholder="Select seating"
                options={[
                  { value: '2', label: '2 Pitmasters' },
                  { value: '4', label: '4 Pitmasters' },
                  { value: '6', label: '6 Pitmasters' },
                  { value: '8', label: '8+ (Private Table)' },
                ]}
              />
              <CustomDropdown
                name="preference"
                label="Hearth Preference"
                placeholder="Select preference"
                options={[
                  { value: 'tandoor-side', label: 'Tandoor Side (Direct clay oven view)' },
                  { value: 'sigree-view', label: 'Sigree Grill View (Plated kebabs prep view)' },
                  {
                    value: 'biryani-lounge',
                    label: 'Biryani Hearth Lounge (Aromatic claypot steam)',
                  },
                  { value: 'chefs-table', label: "Chef's Table (Curated multi-course tasting)" },
                ]}
              />
            </div>

            <!-- Submit -->
            <Button
              as="button"
              type="button"
              variant="primary"
              class="mt-4 text-[12px] tracking-[2px] py-4 gap-2 self-center px-8"
            >
              Reserve Hearth Seating
            </Button>
          </form>

          <BookingToast />
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  import { gsap } from 'gsap';

  document.addEventListener('DOMContentLoaded', () => {
    const ctrl = new AbortController();
    const reserveSection = document.querySelector('.reserve-section') as HTMLElement;
    const reserveInfo = document.querySelector('.reserve-info') as HTMLElement;
    const reservationCardWrapper = document.querySelector('.reserve-card-wrap') as HTMLElement;
    const primaryHearthGlow = document.querySelector('.hearth-glow') as HTMLElement;
    const secondaryHearthGlow = document.querySelector('.hearth-glow-secondary') as HTMLElement;

    if (!reserveSection) return;

    // Entrance Animations via ScrollTrigger
    gsap.from(reserveInfo?.children, {
      y: 40,
      opacity: 0,
      stagger: 0.12,
      duration: 0.8,
      ease: 'power3.out',
      scrollTrigger: {
        trigger: reserveSection,
        start: 'top 75%',
        toggleActions: 'play none none none',
      },
    });

    gsap.from(reservationCardWrapper, {
      y: 60,
      scale: 0.96,
      opacity: 0,
      duration: 1.0,
      ease: 'back.out(1.5)',
      scrollTrigger: {
        trigger: reserveSection,
        start: 'top 70%',
        toggleActions: 'play none none none',
      },
    });

    gsap.fromTo(
      [primaryHearthGlow, secondaryHearthGlow],
      { scale: 0.7, opacity: 0 },
      {
        scale: 1.25,
        opacity: 0.45,
        duration: 1.8,
        ease: 'power2.out',
        scrollTrigger: {
          trigger: reserveSection,
          start: 'top 80%',
          toggleActions: 'play none none none',
        },
      },
    );

    // Reserve button click → show toast
    const reserveButton = reserveSection.querySelector(
      'form > .hover-button[type="button"]',
    ) as HTMLElement | null;

    if (reserveButton) {
      reserveButton.addEventListener(
        'click',
        (e) => {
          e.preventDefault();
          document.dispatchEvent(new CustomEvent('bonfire:show-toast'));
        },
        { signal: ctrl.signal },
      );
    }
  });
</script>
