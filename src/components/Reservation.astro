---
---
<section id="reserve" class="reserve-section relative w-full min-h-screen bg-canvas-black py-24 flex items-center justify-center overflow-hidden border-t border-white/5">
  
  <!-- Glowing hearth backdrop (expanding fire glow) -->
  <div class="absolute w-[500px] h-[500px] rounded-full bg-brand-purple/20 filter blur-[120px] pointer-events-none z-0 hearth-glow"></div>
  <div class="absolute w-[300px] h-[300px] rounded-full bg-brand-mint/10 filter blur-[80px] pointer-events-none z-0 hearth-glow-secondary"></div>

  <div class="max-w-6xl mx-auto w-full px-6 md:px-12 relative z-10">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-16 items-center">
      
      <!-- Left Column: Primal Booking Invitation (6 Cols) -->
      <div class="lg:col-span-6 flex flex-col gap-6 reserve-info">
        <span class="text-brand-mint font-mono text-xs uppercase tracking-[2.5px] block">JOIN THE CIRCLE</span>
        <h2 class="font-display text-5xl md:text-8xl uppercase leading-[0.85] font-black text-hazard-white tracking-tight">
          SECURE YOUR HEARTH
        </h2>
        <p class="font-serif italic text-base md:text-lg text-hazard-white/70 leading-relaxed max-w-lg mt-2">
          "The woodfire pit burns daily, fueled by century-old heritage oaks. Seating is strictly limited to ensure individual culinary pacing."
        </p>
        
        <ul class="flex flex-col gap-4 mt-4 font-sans text-xs md:text-sm text-secondary-text">
          <li class="flex items-center gap-3">
            <span class="w-1.5 h-1.5 rounded-full bg-brand-mint"></span>
            <span>Direct view of the live fire pit hearth</span>
          </li>
          <li class="flex items-center gap-3">
            <span class="w-1.5 h-1.5 rounded-full bg-brand-mint"></span>
            <span>Pitmaster selection tasting notes included</span>
          </li>
          <li class="flex items-center gap-3">
            <span class="w-1.5 h-1.5 rounded-full bg-brand-mint"></span>
            <span>Exclusive smokehouse tour access post-meal</span>
          </li>
        </ul>
      </div>

      <!-- Right Column: Booking Card Form (6 Cols) -->
      <div class="lg:col-span-6 reserve-card-wrap">
        <div class="bg-surface-slate border border-white/10 rounded-[24px] p-6 md:p-8 flex flex-col gap-6 relative shadow-2xl overflow-hidden hover:border-brand-mint/30 transition-all duration-300">
          <div class="flex justify-between items-baseline border-b border-white/5 pb-4">
            <span class="font-mono text-[10px] uppercase tracking-[2px] text-brand-mint font-semibold">HEARTH BOOKING</span>
            <span class="font-mono text-[9px] text-secondary-text">CODE: PIT-001</span>
          </div>

          <form class="flex flex-col gap-5" onsubmit="event.preventDefault(); alert('Your hearth is reserved. Prepare for the smoke.');">
            <!-- Grid row -->
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
              <!-- Name Input -->
              <div class="flex flex-col gap-2">
                <label for="name" class="font-mono text-[10px] uppercase tracking-[1.5px] text-hazard-white/80">Your Name</label>
                <input 
                  type="text" 
                  id="name" 
                  placeholder="e.g. Marcus Aurelius" 
                  required
                  class="bg-canvas-black border border-white/20 text-sm font-sans text-hazard-white placeholder-secondary-text px-4 py-3 rounded-[2px] focus:outline-none focus:border-brand-mint focus:ring-1 focus:ring-brand-purple transition-all duration-150"
                />
              </div>
              <!-- Email Input -->
              <div class="flex flex-col gap-2">
                <label for="email" class="font-mono text-[10px] uppercase tracking-[1.5px] text-hazard-white/80">Email Address</label>
                <input 
                  type="email" 
                  id="email" 
                  placeholder="e.g. pit@bonfire.com" 
                  required
                  class="bg-canvas-black border border-white/20 text-sm font-sans text-hazard-white placeholder-secondary-text px-4 py-3 rounded-[2px] focus:outline-none focus:border-brand-mint focus:ring-1 focus:ring-brand-purple transition-all duration-150"
                />
              </div>
            </div>

            <!-- Grid row -->
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
              <!-- Date/Time Picker -->
              <div class="flex flex-col gap-2">
                <label for="datetime" class="font-mono text-[10px] uppercase tracking-[1.5px] text-hazard-white/80">Arrival Time</label>
                <input 
                  type="datetime-local" 
                  id="datetime" 
                  required
                  class="bg-canvas-black border border-white/20 text-sm font-sans text-hazard-white px-4 py-3 rounded-[2px] focus:outline-none focus:border-brand-mint focus:ring-1 focus:ring-brand-purple transition-all duration-150"
                />
              </div>
              <!-- Guests Count -->
              <div class="flex flex-col gap-2">
                <label for="guests" class="font-mono text-[10px] uppercase tracking-[1.5px] text-hazard-white/80">Hearth Seating</label>
                <select 
                  id="guests"
                  class="bg-canvas-black border border-white/20 text-sm font-sans text-hazard-white px-4 py-3 rounded-[2px] focus:outline-none focus:border-brand-mint focus:ring-1 focus:ring-brand-purple transition-all duration-150"
                >
                  <option value="2">2 Pitmasters</option>
                  <option value="4">4 Pitmasters</option>
                  <option value="6">6 Pitmasters</option>
                  <option value="8">8+ (Private Table)</option>
                </select>
              </div>
            </div>

            <!-- Select Table Preference -->
            <div class="flex flex-col gap-2">
              <label for="preference" class="font-mono text-[10px] uppercase tracking-[1.5px] text-hazard-white/80">Hearth Preference</label>
              <select 
                id="preference"
                class="bg-canvas-black border border-white/20 text-sm font-sans text-hazard-white px-4 py-3 rounded-[2px] focus:outline-none focus:border-brand-mint focus:ring-1 focus:ring-brand-purple transition-all duration-150"
              >
                <option value="pit-side">Fire Pit Side (High Heat & Direct Flame views)</option>
                <option value="grill-view">Grill View (Plated dishes preparation view)</option>
                <option value="smokehouse">Smokehouse Lounge (Chill, wood smoke aroma)</option>
                <option value="chefs-table">Chef's Table (Curated multi-course tasting)</option>
              </select>
            </div>

            <!-- Submit CTA -->
            <button 
              type="submit" 
              class="magnetic-button w-full mt-4 bg-brand-mint hover:bg-white/20 text-canvas-black hover:text-hazard-white font-mono text-[12px] font-bold uppercase tracking-[2px] py-4 rounded-full border border-transparent hover:border-white/20 transition-all duration-180 flex items-center justify-center gap-2 cursor-pointer group"
            >
              <span class="magnetic-target block">Reserve Hearth Seating</span>
            </button>
          </form>
        </div>
      </div>

    </div>
  </div>
</section>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  document.addEventListener('DOMContentLoaded', () => {
    const section = document.querySelector('.reserve-section') as HTMLElement;
    const info = document.querySelector('.reserve-info') as HTMLElement;
    const cardWrap = document.querySelector('.reserve-card-wrap') as HTMLElement;
    const glow = document.querySelector('.hearth-glow') as HTMLElement;
    const glowSec = document.querySelector('.hearth-glow-secondary') as HTMLElement;
    const inputs = document.querySelectorAll('input, select');
    const submitBtn = document.querySelector('.magnetic-button') as HTMLElement;

    if (!section) return;

    // 1. Entrance Animations via ScrollTrigger
    // Text staggers up and the card scales up slightly
    gsap.from(info.children, {
      y: 40,
      opacity: 0,
      stagger: 0.12,
      duration: 0.8,
      ease: 'power3.out',
      scrollTrigger: {
        trigger: section,
        start: 'top 75%',
        toggleActions: 'play none none none'
      }
    });

    gsap.from(cardWrap, {
      y: 60,
      scale: 0.96,
      opacity: 0,
      duration: 1.0,
      ease: 'back.out(1.5)',
      scrollTrigger: {
        trigger: section,
        start: 'top 70%',
        toggleActions: 'play none none none'
      }
    });

    // Backlighting glow softly expands on entry
    gsap.fromTo([glow, glowSec], 
      { scale: 0.7, opacity: 0 },
      { 
        scale: 1.25, 
        opacity: 0.45, 
        duration: 1.8, 
        ease: 'power2.out',
        scrollTrigger: {
          trigger: section,
          start: 'top 80%',
          toggleActions: 'play none none none'
        }
      }
    );

    // 2. Form Input Micro-interactions (Focus rings)
    // Handled in CSS, but let's add custom magnetic responses on CTA submit button
    if (submitBtn) {
      const target = submitBtn.querySelector('.magnetic-target') || submitBtn;
      
      submitBtn.addEventListener('mousemove', (e: any) => {
        const rect = submitBtn.getBoundingClientRect();
        const x = e.clientX - rect.left - rect.width / 2;
        const y = e.clientY - rect.top - rect.height / 2;
        
        gsap.to(target, {
          x: x * 0.4,
          y: y * 0.4,
          duration: 0.3,
          ease: 'power2.out'
        });
      });
      
      submitBtn.addEventListener('mouseleave', () => {
        gsap.to(target, {
          x: 0,
          y: 0,
          duration: 0.6,
          ease: 'elastic.out(1.2, 0.4)'
        });
      });
    }
  });
</script>
