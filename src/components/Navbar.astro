---
import Button from './Button.astro';

const navLinks = [
  { href: '#about', label: 'Timeline' },
  { href: '#dishes', label: 'Menu' },
  { href: '#gallery', label: 'Atmosphere' },
];
const mobileOnlyLinks = [{ href: '#reserve', label: 'Book Table' }];
---

<header
  class="navbar-wrapper fixed top-0 left-0 w-full z-50 px-4 md:px-8 py-6 transition-[padding,background-color,border-color] duration-300"
>
  <div
    class="navbar-container max-w-7xl mx-auto flex items-center justify-between bg-canvas-black border border-white/10 rounded-3xl px-6 py-3 transition-[padding,background-color,border-color] duration-300"
  >
    <!-- Brand Logo -->
    <a href="#hero" class="brand-logo flex items-center gap-2 group cursor-pointer">
      <span
        class="logo-icon w-8 h-8 rounded-lg bg-brand-mint flex items-center justify-center font-display text-canvas-black text-xl font-black"
        >B</span
      >
      <span class="font-display text-2xl tracking-wider text-hazard-white select-none">BONFIRE</span
      >
    </a>

    <!-- Nav Links (Desktop) -->
    <nav class="hidden md:flex items-center gap-8 relative py-1">
      {
        navLinks.map((link) => (
          <a
            href={link.href}
            class="nav-link relative text-xs font-mono uppercase tracking-[1.8px] text-hazard-white/80 hover:text-brand-mint transition-colors duration-200 py-1"
          >
            <span>{link.label}</span>
          </a>
        ))
      }
      <!-- Fluid Animated Active Indicator Line -->
      <div
        id="nav-active-indicator"
        class="absolute bottom-0 left-0 h-[2px] bg-brand-mint rounded-full pointer-events-none opacity-0 shadow-[0_0_8px_#3cffd0]"
      >
      </div>
    </nav>

    <!-- Right Side CTA -->
    <div class="flex items-center gap-4">
      <div class="hidden md:block">
        <Button
          href="#reserve"
          variant="primary"
          class="nav-cta text-[11px] font-semibold tracking-[1.5px] px-6 py-2.5"
        >
          Book Table
        </Button>
      </div>

      <!-- Mobile Menu Toggle -->
      <button
        class="mobile-toggle p-2 text-hazard-white md:hidden hover:text-brand-mint"
        aria-label="Toggle Menu"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          class="h-6 w-6"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M4 6h16M4 12h16m-7 6h7"></path>
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile Drawer Menu -->
  <div
    class="mobile-drawer fixed inset-y-0 right-0 w-64 bg-canvas-black/95 backdrop-blur-lg border-l border-white/10 p-8 transform translate-x-full transition-transform duration-300 z-50 flex flex-col gap-8 shadow-2xl"
  >
    <div class="flex justify-between items-center">
      <span class="font-display text-xl tracking-wider text-hazard-white">BONFIRE</span>
      <button
        class="mobile-close p-2 text-hazard-white hover:text-brand-mint"
        aria-label="Close Menu"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          class="h-6 w-6"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M6 18L18 6M6 6l12 12"></path>
        </svg>
      </button>
    </div>
    <nav class="flex flex-col gap-6 mt-8">
      {
        navLinks.map((link) => (
          <a
            href={link.href}
            class="mobile-nav-link text-lg font-mono uppercase tracking-[2px] text-hazard-white hover:text-link-blue transition-colors py-3"
          >
            {link.label}
          </a>
        ))
      }
      {
        mobileOnlyLinks.map((link) => (
          <a
            href={link.href}
            class="mobile-nav-link text-lg font-mono uppercase tracking-[2px] text-brand-mint hover:text-link-blue transition-colors py-3"
          >
            {link.label}
          </a>
        ))
      }
    </nav>
  </div>
</header>

<style>
  /* Sticky navbar styles */
  .navbar-container {
    background-color: rgba(45, 45, 45, 0.9);
    backdrop-filter: blur(12px);
    border-color: #3cffd0;
  }
</style>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  import { handleNavClick } from '../utils/navigateWithTransition';

  gsap.registerPlugin(ScrollTrigger);

  document.addEventListener('DOMContentLoaded', () => {
    const brandLogoElement = document.querySelector('.brand-logo') as HTMLElement | null;
    const desktopNavLinkElements = Array.from(
      document.querySelectorAll('.nav-link'),
    ) as HTMLElement[];
    const navCtaButtons = document.querySelectorAll('.nav-cta');
    const mobileNavLinks = document.querySelectorAll('.mobile-nav-link');
    const mobileToggle = document.querySelector('.mobile-toggle');
    const mobileClose = document.querySelector('.mobile-close');
    const mobileDrawer = document.querySelector('.mobile-drawer');
    const desktopNavContainer = document.querySelector('nav') as HTMLElement | null;
    const activeNavIndicator = document.getElementById(
      'nav-active-indicator',
    ) as HTMLElement | null;

    // Mobile drawer open/close
    mobileToggle?.addEventListener('click', () => {
      mobileDrawer?.classList.remove('translate-x-full');
    });

    mobileClose?.addEventListener('click', () => {
      mobileDrawer?.classList.add('translate-x-full');
    });

    // Nav link & CTA clicks via page transition
    brandLogoElement?.addEventListener('click', handleNavClick);
    desktopNavLinkElements.forEach((navLinkElement) =>
      navLinkElement.addEventListener('click', handleNavClick),
    );
    navCtaButtons.forEach((ctaButton) => ctaButton.addEventListener('click', handleNavClick));
    mobileNavLinks.forEach((mobileLink) => {
      mobileLink.addEventListener('click', (event) => {
        handleNavClick(event);
        mobileDrawer?.classList.add('translate-x-full');
      });
    });

    // Map href -> navLinkElement for O(1) active class updates
    const sectionToNavLinkMap = new Map<string, HTMLElement>();
    desktopNavLinkElements.forEach((navLink) => {
      const targetHref = navLink.getAttribute('href');
      if (targetHref) sectionToNavLinkMap.set(targetHref, navLink);
    });

    // Smooth fluid indicator animation function
    const updateActiveIndicatorPosition = (targetNavLink: HTMLElement | null) => {
      if (!activeNavIndicator || !desktopNavContainer) return;

      if (!targetNavLink) {
        gsap.to(activeNavIndicator, {
          autoAlpha: 0,
          duration: 0.25,
          ease: 'power2.out',
        });
        desktopNavLinkElements.forEach((navLink) => {
          navLink.classList.remove('text-brand-mint');
          navLink.classList.add('text-hazard-white/80');
        });
        return;
      }

      const desktopNavContainerRect = desktopNavContainer.getBoundingClientRect();
      const activeTargetLinkRect = targetNavLink.getBoundingClientRect();
      const indicatorLeftPosition = activeTargetLinkRect.left - desktopNavContainerRect.left;
      const indicatorTargetWidth = activeTargetLinkRect.width;

      gsap.to(activeNavIndicator, {
        autoAlpha: 1,
        x: indicatorLeftPosition,
        width: indicatorTargetWidth,
        duration: 0.38,
        ease: 'power3.out',
        overwrite: 'auto',
      });

      desktopNavLinkElements.forEach((navLink) => {
        if (navLink === targetNavLink) {
          navLink.classList.remove('text-hazard-white/80');
          navLink.classList.add('text-brand-mint');
        } else {
          navLink.classList.remove('text-brand-mint');
          navLink.classList.add('text-hazard-white/80');
        }
      });
    };

    // ScrollTrigger active link highlighting for section scroll
    const navSectionSelectorIds = ['#hero', '#about', '#dishes', '#gallery', '#reserve'];
    navSectionSelectorIds.forEach((sectionSelectorId) => {
      const sectionElement = document.querySelector(sectionSelectorId);
      if (!sectionElement) return;
      ScrollTrigger.create({
        trigger: sectionElement,
        start: sectionSelectorId === '#hero' ? 'top top' : 'top 40%',
        end: 'bottom 40%',
        onToggle: (scrollTriggerInstance) => {
          if (scrollTriggerInstance.isActive) {
            const activeNavLink = sectionToNavLinkMap.get(sectionSelectorId) || null;
            updateActiveIndicatorPosition(sectionSelectorId === '#hero' ? null : activeNavLink);
          }
        },
      });
    });

    // Re-calculate indicator position on window resize
    window.addEventListener('resize', () => {
      const activeNavLink = desktopNavLinkElements.find((navLink) =>
        navLink.classList.contains('text-brand-mint'),
      );
      if (activeNavLink) updateActiveIndicatorPosition(activeNavLink);
    });
  });
</script>
